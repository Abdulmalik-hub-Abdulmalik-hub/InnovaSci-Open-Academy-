  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  category    String   @default("general") // general, appearance, integrations, security, email, payments, storage
  description String? // Human-readable description
  isPublic    Boolean  @default(false) // Accessible without auth
  isEncrypted Boolean  @default(false) // Encrypt value in DB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USERS - Only Admin and Student roles
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          String    @default("STUDENT")  // Only: ADMIN, STUDENT
  status        String    @default("ACTIVE")   // ACTIVE, INACTIVE, SUSPENDED
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  profile      Profile?
  enrollments  Enrollment[]
  certificates Certificate[]
  payments     Payment[]
  notifications Notification[]
  wishlists    Wishlist[]
  subscriptions Subscription[]
  auditLogs    AuditLog[]
  learningProgress LearningProgress[]
  userLectureProgress UserLectureProgress[]
  learningPathProgress LearningPathProgress[]
  supportTickets SupportTicket[]
  ticketComments TicketComment[]
  
  @@map("users")
}

// ============================================
// 2. PROFILES - User details
// ============================================

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String?
  username    String?  @unique
  phone       String?
  country     String?
  city        String?
  gender      String?
  bio         String?
  avatarUrl   String?
  status      String   @default("active")
  preferences Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("profiles")
}

// ============================================
// 3. COURSES - Content managed by Admin
// ============================================

model Course {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  category         String?
  subcategory      String?
  shortDescription String?
  fullDescription  String?  @db.Text
  learningOutcomes String?  @db.Text
  prerequisites    String?  @db.Text
  targetAudience   String?
  difficultyLevel  String?
  language         String   @default("English")
  durationHours    Int?
  thumbnailUrl     String?
  promoVideoUrl    String?
  price            Decimal  @default(0)
  isFree           Boolean  @default(true)
  status           String   @default("draft")  // draft, published, archived
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  modules     Module[]
  lessons     Lesson[]
  enrollments Enrollment[]
  certificates Certificate[]
  wishlists   Wishlist[]
  learningProgress LearningProgress[]
  
  // Learning Paths
  learningPaths LearningPathCourse[]
  
  @@map("courses")
}

// ============================================
// 4. MODULES - Course sections
// ============================================

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  
  @@unique([courseId, orderIndex])
  @@map("modules")
}

// ============================================
// 5. LESSONS - Course content
// ============================================

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  moduleId    String?
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  lessonType  String   @default("video")  // video, quiz, lab, reading
  duration    Int?     // Duration in seconds
  videoUrl    String?
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  course     Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module     Module?            @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  materials  Material[]
  videos     Video[]
  progress   LearningProgress[]
  lectureProgress UserLectureProgress[]
  
  @@map("lessons")
}

// ============================================
// 6. MATERIALS - Lesson attachments
// ============================================

model Material {
  id              String   @id @default(uuid())
  lessonId        String
  title           String
  type            String?
  fileUrl         String
  visibility      String   @default("public")
  downloadAllowed Boolean  @default(true)
  createdAt       DateTime @default(now())
  
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@map("materials")
}

// ============================================
// 7. VIDEOS - Lesson video content
// ============================================

model Video {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  videoUrl    String
  duration    Int?
  provider    String?
  storageType String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@map("videos")
}

// ============================================
// 8. ENROLLMENTS - Student course access
// ============================================

model Enrollment {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  progressPercent Int      @default(0)
  completed       Boolean  @default(false)
  enrolledAt      DateTime @default(now())
  completedAt     DateTime?
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("enrollments")
}

// ============================================
// 9. LEARNING PROGRESS - Lesson completion
// ============================================

model LearningProgress {
  id         String    @id @default(uuid())
  userId     String
  courseId   String
  lessonId   String
  completed  Boolean   @default(false)
  watchTime  Int       @default(0)
  completedAt DateTime?
  updatedAt  DateTime  @updatedAt
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// ============================================
// 10. USER LECTURE PROGRESS - Detailed tracking
// ============================================

model UserLectureProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  courseId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  watchTime    Int       @default(0)
  lastPosition Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@map("user_lecture_progress")
}

// ============================================
// 11. CERTIFICATES - Course completion certificates
// ============================================

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  certificateUrl    String?
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  status           String   @default("issued")  // issued, revoked
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("certificates")
}

// ============================================
// 12. PAYMENTS - Transaction records
// ============================================

model Payment {
  id                String   @id @default(uuid())
  userId            String
  amount            Decimal
  currency          String   @default("NGN")
  status            String   @default("PENDING")  // PENDING, COMPLETED, FAILED, REFUNDED
  paymentMethod     String?
  transactionId     String?
  paystackReference String?
  channel           String?
  authorizationCode String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("payments")
}

// ============================================
// 13. PLANS - Subscription plans
// ============================================

model Plan {
  id                   String   @id @default(uuid())
  name                 String
  description          String?  @db.Text
  planType             String   @default("subscription")  // subscription, one_time
  billingCycle         String   @default("monthly")  // monthly, yearly, lifetime
  price                Decimal
  currency             String   @default("USD")
  stripePriceId        String?  @unique
  paystackPlanId       String?  @unique
  features             Json?    @default("[]")
  isActive             Boolean  @default(true)
  isFeatured           Boolean  @default(false)
  discountPercentage    Int?     @default(0)  // For limited-time offers
  promoCode            String?
  maxCourses           Int?     @default(-1)  // -1 for unlimited
  maxCertificates      Int?     @default(-1)
  allowedCourseIds     String[] @default([])
  trialDays            Int?     @default(0)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  subscriptions Subscription[]
  
  @@map("plans")
}

// ============================================
// 14. SUBSCRIPTIONS - Membership subscriptions
// ============================================

model Subscription {
  id             String    @id @default(uuid())
  userId         String
  planId         String?
  planName       String    @default("FREE")  // FREE, PRO, TEAM (legacy)
  status         String    @default("active")  // active, cancelled, expired, trialing
  startDate      DateTime  @default(now())
  endDate        DateTime?
  recurringPrice Decimal?
  isPro          Boolean   @default(false)
  autoRenew      Boolean   @default(true)
  paystackSubscriptionCode String?
  stripeSubscriptionId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  @@map("subscriptions")
}

// ============================================
// 15. LEARNING PATHS - Course roadmaps
// ============================================

model LearningPath {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  thumbnailUrl String?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  pathCourses  LearningPathCourse[]
  userProgress LearningPathProgress[]
  
  @@map("learning_paths")
}

// ============================================
// 15. LEARNING PATH COURSES - Junction table
// ============================================

model LearningPathCourse {
  id              String   @id @default(uuid())
  learningPathId  String
  courseId        String
  orderIndex      Int      @default(0)
  isRequired      Boolean  @default(true)
  createdAt       DateTime @default(now())
  
  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([learningPathId, courseId])
  @@map("learning_path_courses")
}

// ============================================
// 16. LEARNING PATH PROGRESS - User progress
// ============================================

model LearningPathProgress {
  id              String    @id @default(uuid())
  userId          String
  learningPathId  String
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  progressPercent Int       @default(0)
  
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  
  @@unique([userId, learningPathId])
  @@map("learning_path_progress")
}

// ============================================
// 17. WISHLISTS - Saved courses
// ============================================

model Wishlist {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  addedAt  DateTime @default(now())
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("wishlists")
}

// ============================================
// 18. NOTIFICATIONS - User alerts
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")  // info, success, warning, error
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

// ============================================
// 19. AUDIT LOGS - Activity tracking
// ============================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("audit_logs")
}

// ============================================
// 20. SUPPORT TICKETS - Help requests
// ============================================

model SupportTicket {
  id         String    @id @default(uuid())
  userId     String?
  email      String
  category   String    // billing, course-access, technical, business, partnership, other
  subject    String?
  message    String    @db.Text
  status     String    @default("open")   // open, in_progress, resolved, closed
  priority   String    @default("medium") // low, medium, high, urgent
  assignedTo String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
  
  user     User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments TicketComment[]
  
  @@map("support_tickets")
}

// ============================================
// 21. TICKET COMMENTS - Support replies
// ============================================

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String?
  message    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("ticket_comments")
}

// ============================================
// 22. NEWSLETTER SUBSCRIBERS
// ============================================

model NewsletterSubscriber {
  id           String    @id @default(uuid())
  email        String    @unique
  isActive     Boolean   @default(true)
  subscribedAt DateTime  @default(now())
  unsubscribedAt DateTime?
  
  @@map("newsletter_subscribers")
}

// ============================================
// 23. SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("string")
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("system_settings")
}

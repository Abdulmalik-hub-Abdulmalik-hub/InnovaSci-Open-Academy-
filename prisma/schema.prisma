generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Profiles & Users Extension
model Profile {
  id          String   @id @default(uuid())
  fullName    String?
  username    String?  @unique
  phone       String?
  country     String?
  state       String?
  city        String?
  gender      String?
  bio         String?
  avatarUrl   String?
  role        String   @default("student")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  courses       Course[]
  enrollments   Enrollment[]
  progress      LearningProgress[]
  certificates  Certificate[]
  userRoles     UserRole[]
  subscriptions Subscription[]
  payments      Payment[]
  wishlists     Wishlist[]
  notifications Notification[]
  auditLogs     AuditLog[]
  
  @@map("profiles")
}

// 2. RBAC & Permissions
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  permissions RolePermission[]
  userRoles   UserRole[]
  
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  
  roles RolePermission[]
  
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  createdAt DateTime @default(now())
  
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@id([userId, roleId])
  @@map("user_roles")
}

// 3. Course System
model Course {
  id               String   @id @default(uuid())
  title            String
  code             String?  @unique
  category         String?
  subcategory      String?
  shortDescription String?
  fullDescription  String?  @db.Text
  learningOutcomes String?  @db.Text
  prerequisites    String?  @db.Text
  targetAudience   String?
  difficultyLevel  String?
  language         String?
  durationHours    Int?
  thumbnailUrl     String?
  promoVideoUrl   String?
  price            Decimal  @default(0)
  isFree           Boolean  @default(true)
  status           String   @default("draft")
  instructorId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  instructor  Profile?
  lessons     Lesson[]
  enrollments Enrollment[]
  progress    LearningProgress[]
  certificates Certificate[]
  wishlists   Wishlist[]
  
  @@map("courses")
}

// 4. Enrollments & Progress
model Enrollment {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  progressPercent Int      @default(0)
  completed       Boolean  @default(false)
  enrolledAt      DateTime @default(now())
  
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("enrollments")
}

model LearningProgress {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  lessonId   String
  completed  Boolean  @default(false)
  watchTime  Int      @default(0)
  updatedAt  DateTime @updatedAt
  
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// 5. Content, Materials, Videos
model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  course    Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
  videos    Video[]
  progress  LearningProgress[]
  
  @@map("lessons")
}

model Material {
  id             String   @id @default(uuid())
  lessonId       String
  title          String
  type           String?
  fileUrl        String
  visibility     String   @default("public")
  downloadAllowed Boolean @default(true)
  createdAt      DateTime @default(now())
  
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@map("materials")
}

model Video {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  videoUrl    String
  duration    Int?
  provider    String?
  storageType String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@map("videos")
}

// 6. Certificates Engine
model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  certificateUrl   String?
  templateUrl      String?
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  status           String   @default("issued")
  
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@map("certificates")
}

// 7. Subscriptions & Payments
model Subscription {
  id              String   @id @default(uuid())
  userId          String
  plan            String
  status          String   @default("active")
  startDate       DateTime @default(now())
  endDate         DateTime?
  recurringPrice  Decimal?
  createdAt       DateTime @default(now())
  
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  amount          Decimal
  currency        String   @default("USD")
  status          String   @default("pending")
  paymentMethod   String?
  transactionId   String?
  metadata        Json?
  createdAt       DateTime @default(now())
  
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("payments")
}

// 8. Newsletters
model Newsletter {
  id          String   @id @default(uuid())
  title       String
  subject     String
  content     String   @db.Text
  status      String   @default("draft")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  
  logs NewsletterLog[]
  
  @@map("newsletters")
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  name        String?
  subscribed  Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?
  
  logs NewsletterLog[]
  
  @@map("newsletter_subscribers")
}

model NewsletterLog {
  id              String   @id @default(uuid())
  newsletterId    String
  subscriberId    String
  sentAt          DateTime @default(now())
  openedAt        DateTime?
  clickedAt        DateTime?
  bouncedAt        DateTime?
  
  newsletter Newsletter         @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  subscriber NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  @@map("newsletter_logs")
}

// 9. Storage
model StorageFile {
  id          String   @id @default(uuid())
  filename    String
  path        String
  size        Int?
  mimeType    String?
  storageType String   @default("supabase")
  bucket      String?
  createdAt   DateTime @default(now())
  
  @@map("storage_files")
}

// 10. Analytics
model AnalyticsEvent {
  id          String   @id @default(uuid())
  eventType   String
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  
  @@map("analytics_events")
}

// 11. Notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

// 12. Audit Logs
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
  
  user Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@map("audit_logs")
}

// 13. Wishlists
model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  addedAt   DateTime @default(now())
  
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("wishlists")
}

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("career_outcomes")
}

// ============================================
// 39. INSTRUCTORS
// ============================================
model Instructor {
  id          String   @id @default(uuid())
  userId      String?  // Optional link to User
  name        String
  title       String?
  bio         String?  @db.Text
  avatarUrl   String?
  expertise   String[] // Areas of expertise
  socialLinks Json?    // { linkedin, twitter, website }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("instructors")
}

// ============================================
// 40. PRACTICAL EXERCISES (Per Lesson)
// ============================================
model PracticalExercise {
  id                String   @id @default(uuid())
  lessonId          String   @unique
  instructions      String?  @db.Text // Markdown instructions
  starterCode       String?  @db.Text
  solutionCode      String?  @db.Text
  hints             Json?    // Array of hint strings
  rubric            Json?    // { criteria: [{ name, points, description }] }
  maxScore          Int      @default(100)
  passingScore      Int      @default(70)
  timeLimit         Int?     // In minutes
  isRequired        Boolean  @default(false)
  allowRetry        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("practical_exercises")
}

// ============================================
// 41. MINI PROJECTS (Per Course)
// ============================================
model MiniProject {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  description     String?  @db.Text
  scenario        String?  @db.Text // Real-world scenario
  workflow        String?  @db.Text // Step-by-step workflow
  deliverables    Json?    // { required: [...], optional: [...] }
  evaluationRubric Json?   // { criteria: [...] }
  starterFilesUrl String?
  solutionFilesUrl String?
  maxScore        Int      @default(100)
  passingScore    Int      @default(70)
  isRequired      Boolean  @default(false)
  dueDaysAfterStart Int?   // Due X days after course enrollment
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  projectSubmissions ProjectSubmission[]

  @@index([courseId])
  @@map("mini_projects")
}

// ============================================
// 42. DIFFICULTY LEVEL CAPSTONES
// ============================================
model DifficultyLevelCapstone {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  difficultyLevel String   // BEGINNER, INTERMEDIATE, ADVANCED
  includedCourses Json?    // Array of course IDs
  orderIndex      Int      @default(0)
  isPublished     Boolean  @default(false)
  thumbnailUrl    String?
  certificateTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments     CapstoneEnrollment[]

  @@index([difficultyLevel])
  @@index([isPublished])
  @@map("difficulty_level_caps")
}

// ============================================
// 43. PROFESSIONAL CAPSTONES
// ============================================
model ProfessionalCapstone {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  categoryId      String?
  includedCourses Json?    // Array of course IDs
  requirements    String?  @db.Text
  deliverables    Json?    // { required: [...] }
  evaluationCriteria Json? // { criteria: [...] }
  orderIndex      Int      @default(0)
  isPublished     Boolean  @default(false)
  thumbnailUrl    String?
  certificateTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments     CapstoneEnrollment[]

  @@index([categoryId])
  @@index([isPublished])
  @@map("professional_caps")
}

// ============================================
// 44. CAPSTONE ENROLLMENTS
// ============================================
model CapstoneEnrollment {
  id                    String   @id @default(uuid())
  userId                String
  difficultyCapstoneId   String?
  professionalCapstoneId String?
  progressPercent       Int      @default(0)
  status                String   @default("not_started") // not_started, in_progress, submitted, graded
  submittedAt           DateTime?
  grade                 Int?
  feedback              String?  @db.Text
  certificateId         String?
  enrolledAt            DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  difficultyCapstone    DifficultyLevelCapstone? @relation(fields: [difficultyCapstoneId], references: [id], onDelete: SetNull)
  professionalCapstone  ProfessionalCapstone? @relation(fields: [professionalCapstoneId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([difficultyCapstoneId])
  @@index([professionalCapstoneId])
  @@map("capstone_enrollments")
}

// ============================================
// 45. COURSE SEO SETTINGS
// ============================================
model CourseSEO {
  id            String   @id @default(uuid())
  courseId      String   @unique
  metaTitle     String?
  metaDescription String?
  keywords      String[]
  ogImage       String?
  canonicalUrl  String?
  noIndex       Boolean  @default(false)
  noFollow      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_seo")
}

// ============================================
// 46. COURSE VERSIONING
// ============================================
model CourseVersion {
  id          String   @id @default(uuid())
  courseId    String
  version     Int
  changes     String?  @db.Text
  createdBy   String?
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, version])
  @@index([courseId])
  @@map("course_versions")
}

// ============================================
// 47. PROJECT SUBMISSIONS (Student Project Hub)
// ============================================
model ProjectSubmission {
  id              String   @id @default(uuid())
  userId          String
  courseId        String?
  miniProjectId   String?
  capstoneId      String?  // Can be difficulty or professional capstone ID
  capstoneType    String?  // 'difficulty' or 'professional'
  
  // Submission Details
  title           String
  description     String?  @db.Text
  submissionUrl   String?  // GitHub repo or live link
  fileUrls        Json?    // Array of uploaded file URLs
  screenshots     Json?    // Array of screenshot URLs
  
  // Status
  status          String   @default("not_started") // not_started, in_progress, submitted, graded
  grade           Int?
  feedback        String?  @db.Text
  submittedAt      DateTime?
  gradedAt        DateTime?
  
  // MCCS Link
  isFromMCCS      Boolean  @default(false) // Was this imported from MCCS
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  miniProject     MiniProject? @relation(fields: [miniProjectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([miniProjectId])
  @@index([status])
  @@map("project_submissions")
}

// ============================================
// 48. PORTFOLIO ENTRIES (Student Project Vault)
// ============================================
model PortfolioEntry {
  id              String   @id @default(uuid())
  userId          String
  
  // Project Details
  title           String
  description     String?  @db.Text
  liveUrl         String?
  githubUrl       String?
  demoVideoUrl    String?
  
  // Tech Stack
  techStack       String[] // Tags like React, PostgreSQL, etc.
  
  // Media
  screenshots     Json?    // Array of screenshot URLs
  demoVideo       String?  // URL to demo video
  
  // Project Rationale
  rationale       String?  @db.Text
  
  // Privacy & Safety
  visibility      String   @default("PRIVATE") // PRIVATE, PUBLIC, ACADEMY_ONLY
  publicSlug     String?  @unique // Public URL slug: /portfolio/{slug}
  
  // MCCS Link (optional import)
  linkedCourseId   String?
  linkedMiniProjectId String?
  linkedCapstoneId   String?
  
  // Status
  isPublished     Boolean  @default(false)
  viewCount        Int       @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visibility])
  @@index([publicSlug])
  @@map("portfolio_entries")
}

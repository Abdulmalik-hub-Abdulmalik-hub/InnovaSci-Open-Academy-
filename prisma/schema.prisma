generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USERS - Only Admin and Student roles
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          String    @default("STUDENT") // SUPER_ADMIN, ADMIN, STUDENT
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile              Profile?
  enrollments          Enrollment[]
  certificates         Certificate[]
  payments             Payment[]
  notifications        Notification[]
  wishlists            Wishlist[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  learningProgress     LearningProgress[]
  userLectureProgress  UserLectureProgress[]
  learningPathProgress LearningPathProgress[]
  supportTickets       SupportTicket[]
  ticketComments       TicketComment[]
  userRoles            UserRole[]
  Role                 Role?                  @relation(fields: [roleId], references: [id])
  roleId               String?
  IssuedCertificate    IssuedCertificate[]
  forumThreads         ForumThread[]
  forumReplies         ForumReply[]
  instructors          Instructor[]
  capstoneEnrollments  CapstoneEnrollment[]
  projectSubmissions   ProjectSubmission[]
  portfolioEntries     PortfolioEntry[]
  
  // New Certificate Relations
  categoryIssuedCerts    CategoryIssuedCert[]
  domainIssuedCerts     DomainIssuedCert[]
  certificateProgress    CertificateProgress[]
  certificateEligibility CertificateEligibility[]

  // Purchase Relations
  categoryPurchases  CategoryPurchase[]
  domainPurchases    DomainPurchase[]
  academyPurchases   AcademyPurchase[]
  invoices           Invoice[]
  accessLicenses     AccessLicense[]

  // Project Review Relations
  reviewsConducted   ProjectReview[]    @relation("Reviewer")
  reviewAssignments  ReviewerAssignment[]
  commentsAuthored  ProjectComment[]

  // Staff Management Relations
  staffProfile       StaffProfile?

  // Scholarship Relations
  scholarshipApplications ScholarshipApplication[]
  scholarshipApplicationReviews ScholarshipApplicationReview[]
  scholarshipAwards     ScholarshipAward[]
  financialAids         FinancialAid[]
  sponsoredSponsors    Sponsor[]

  @@map("users")
}

// ============================================
// 2. PROFILES - User details
// ============================================

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String?
  username    String?  @unique
  phone       String?
  country     String?
  city        String?
  gender      String?
  bio         String?
  avatarUrl   String?
  status      String   @default("active")
  preferences Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// 3. DOMAINS - Top-level academic domains
// ============================================

model Domain {
  id              String   @id @default(uuid())
  name            String   @unique
  shortName       String?
  slug            String   @unique
  shortDescription String? @db.Text
  fullDescription String? @db.Text
  thumbnailUrl    String?
  bannerUrl       String?
  icon            String?  // Icon name or emoji
  color           String?  // Hex color code
  orderIndex      Int      @default(0)
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visibility      String   @default("PUBLIC") // PUBLIC, PRIVATE, FEATURED
  isFeatured      Boolean  @default(false)
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  categories Category[]
  domainCertificates DomainCertificate[]
  domainPurchases DomainPurchase[]
  
  // Staff Management Relations
  staffAssignments StaffAssignment[]
  projectSupervisors ProjectSupervisor[]

  @@index([slug])
  @@index([status])
  @@index([visibility])
  @@index([isFeatured])
  @@map("domains")
}

// ============================================
// 4. CATEGORIES - Dynamic course categories (belongs to Domain)
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String
  description String?  @db.Text
  icon        String?  // Icon name or emoji
  thumbnailUrl String?
  bannerUrl   String?
  color       String?  // Hex color code
  orderIndex  Int      @default(0)
  isActive    Boolean  @default(true)
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  visibility  String   @default("PUBLIC") // PUBLIC, PRIVATE
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  domainId String?
  domain   Domain? @relation(fields: [domainId], references: [id], onDelete: SetNull)
  courses  Course[]
  categoryCertificate CategoryCertificate?
  categoryPurchases CategoryPurchase[]
  
  // Staff Management Relations
  staffAssignments StaffAssignment[]
  projectSupervisors ProjectSupervisor[]

  @@unique([domainId, slug])
  @@unique([domainId, name])
  @@index([domainId])
  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// 4. COURSES - Content managed by Admin
// ============================================

model Course {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  categoryId       String?  // Foreign key to Category
  subcategory      String?
  shortDescription String?
  fullDescription  String?  @db.Text
  learningOutcomes String?  @db.Text
  prerequisites    String?  @db.Text
  targetAudience   String?
  difficultyLevel  String?
  language         String   @default("English")
  durationHours    Int?
  thumbnailUrl     String?
  promoVideoUrl    String?
  introVideoUrl    String?  // Introduction video for course landing page (mandatory)
  price            Decimal  @default(0) // Legacy single price
  pricing          Json? // Multi-currency: { "NGN": { "amount": 50000 }, "USD": { "amount": 100 } }
  isFree           Boolean  @default(true)
  isActive         Boolean  @default(true) // Admin toggle for visibility
  status           String   @default("draft") // draft, published, archived
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Certificate Template
  certificateTemplateId  String? // Reference to certificate template
  certificateTemplateUrl String? // Legacy URL field

  // MCCS Fields
  instructorId     String?
  whatYouWillLearn Json?  // Array of strings
  requirements     Json?  // Array of strings

  // Relations
  category         Category? @relation(fields: [categoryId], references: [id])
  instructor       Instructor? @relation(fields: [instructorId], references: [id])
  modules          Module[]
  lessons          Lesson[]
  enrollments      Enrollment[]
  certificates     Certificate[]
  wishlists        Wishlist[]
  learningProgress LearningProgress[]
  
  // Certificate Template Relation
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id])

  // Learning Paths
  learningPaths     LearningPathCourse[]
  IssuedCertificate IssuedCertificate[]

  // MCCS Relations
  courseLearningOutcomes CourseLearningOutcome[]
  objectives           CourseObjective[]
  resources            CourseResource[]
  software             CourseSoftware[]
  datasets             CourseDataset[]
  prerequisites_       Prerequisite[]
  careerOutcomes       CareerOutcome[]
  seo                  CourseSEO?
  versions             CourseVersion[]
  miniProjects         MiniProject[]
  projectSubmissions   ProjectSubmission[]
  
  // Staff Management Relations
  staffAssignments StaffAssignment[]
  projectSupervisors ProjectSupervisor[]

  @@map("courses")
}

// ============================================
// 4. MODULES - Course sections
// ============================================

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, orderIndex])
  @@map("modules")
}

// ============================================
// 5. LESSONS - Course content
// ============================================

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  moduleId    String?
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  lessonType  String   @default("video") // video, reading, exercise
  duration    Int? // Duration in seconds
  videoUrl    String?
  isPreview   Boolean  @default(false)
  isFree      Boolean  @default(false) // Free lessons are accessible without enrollment
  isActive    Boolean  @default(true) // Admin toggle for visibility
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Exercise-specific fields
  isExercise          Boolean  @default(false) // Mark this as an exercise/project lesson
  exerciseDescription String?  @db.Text // Markdown description with instructions
  exerciseFilesUrl    String? // URL to downloadable starter files
  solutionVideoUrl    String? // URL to solution walkthrough video

  course          Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module          Module?               @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  materials       Material[]
  videos          Video[]
  progress        LearningProgress[]
  lectureProgress UserLectureProgress[]
  practicalExercise PracticalExercise?

  @@map("lessons")
}

// ============================================
// 6. MATERIALS - Lesson attachments
// ============================================

model Material {
  id              String   @id @default(uuid())
  lessonId        String
  title           String
  type            String?
  fileUrl         String
  visibility      String   @default("public")
  downloadAllowed Boolean  @default(true)
  createdAt       DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("materials")
}

// ============================================
// 7. VIDEOS - Lesson video content
// ============================================

model Video {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  videoUrl    String
  duration    Int?
  provider    String?
  storageType String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("videos")
}

// ============================================
// 8. ENROLLMENTS - Student course access
// ============================================

model Enrollment {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  progressPercent Int       @default(0)
  completed       Boolean   @default(false)
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ============================================
// 9. LEARNING PROGRESS - Lesson completion
// ============================================

model LearningProgress {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  lessonId    String
  completed   Boolean   @default(false)
  watchTime   Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// ============================================
// 10. USER LECTURE PROGRESS - Detailed tracking
// ============================================

model UserLectureProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  courseId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  watchTime    Int       @default(0)
  lastPosition Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@map("user_lecture_progress")
}

// ============================================
// 11. CERTIFICATES - Course completion certificates
// ============================================

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  certificateUrl   String?  @db.Text // Legacy field, use IssuedCertificate for new records
  pdfUrl           String?  @db.Text // URL to PDF in cloud storage
  verificationUrl  String?  @db.Text // Public verification URL
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  status           String   @default("ACTIVE") // ACTIVE, REVOKED

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("certificates")
}

// ============================================
// 11a. CERTIFICATE TEMPLATES - Configurable certificate layouts (ENHANCED)
// ============================================

model CertificateTemplate {
  id           String   @id @default(uuid())
  name         String   // Template name (e.g., "Standard Certificate", "Premium Certificate")
  description  String?  // Template description
  type         String   @default("COURSE") // COURSE, CATEGORY, DOMAIN
  backgroundUrl String  @db.Text // URL to template background image
  width        Int      @default(1200) // Template width in pixels
  height       Int      @default(900) // Template height in pixels
  
  // Field positions (as percentages of template dimensions for responsive rendering)
  studentNameX     Float   @default(0.5) // X position as percentage (0-1)
  studentNameY     Float   @default(0.35) // Y position as percentage (0-1)
  studentNameSize  Int     @default(48) // Font size in pixels
  studentNameFont  String  @default("Georgia") // Font family
  
  courseNameX      Float   @default(0.5)
  courseNameY      Float   @default(0.5)
  courseNameSize   Int     @default(32)
  courseNameFont   String  @default("Georgia")
  
  issueDateX       Float   @default(0.5)
  issueDateY       Float   @default(0.65)
  issueDateSize    Int     @default(24)
  issueDateFont    String  @default("Georgia")
  
  certificateIdX   Float   @default(0.5)
  certificateIdY  Float   @default(0.75)
  certificateIdSize Int    @default(18)
  certificateIdFont String @default("Courier")
  
  // Additional fields for category/domain certificates
  domainNameX           Float?
  domainNameY           Float?
  domainNameSize        Int?
  domainNameFont        String?
  
  categoryNameX         Float?
  categoryNameY         Float?
  categoryNameSize      Int?
  categoryNameFont      String?
  
  certificateTypeX      Float?
  certificateTypeY      Float?
  certificateTypeSize   Int?
  certificateTypeFont   String?
  
  // Signatures
  ceoSignatureX         Float?
  ceoSignatureY         Float?
  ceoSignatureWidth     Int?
  ceoSignatureHeight    Int?
  
  academicDirectorSignatureX     Float?
  academicDirectorSignatureY     Float?
  academicDirectorSignatureWidth Int?
  academicDirectorSignatureHeight Int?
  
  // Official seal
  officialSealX        Float?
  officialSealY        Float?
  officialSealWidth   Int?
  officialSealHeight  Int?
  
  // Styling
  textColor      String   @default("#1a1a2e") // Dark navy color for text
  
  // Status
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  courses Course[]

  @@map("certificate_templates")
}

// ============================================
// 11b. ISSUED CERTIFICATES - Certificate issuance tracking
// ============================================

model IssuedCertificate {
  id              String    @id @default(uuid())
  certificateId   String    @unique // Links to Certificate.id
  studentId       String
  courseId        String
  certificateCode String    @unique // Human-readable code (CERT-2026-XXXX)
  pdfUrl          String?   @db.Text // URL to generated PDF
  verificationUrl String    @db.Text // Public verification URL
  
  // Template snapshot for historical consistency
  // Stores the template configuration at the time of certificate generation
  templateSnapshot Json?    // Snapshot of CertificateTemplate at generation time (stored as JSON)
  
  issuedAt        DateTime  @default(now())
  revokedAt       DateTime?
  revokeReason    String?

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@index([issuedAt])
  @@map("issued_certificates")
}

// ============================================
// 11c. CATEGORY CERTIFICATES - Professional Certificates for completing categories
// ============================================
model CategoryCertificate {
  id              String   @id @default(uuid())
  categoryId      String
  certificateName String   // e.g., "Professional Data Science Certificate"
  description     String?  @db.Text
  requirements    Json?    // Stores requirements: { courses: [], difficultyCapstones: [], professionalCapstone: true }
  templateData   Json?    // Template configuration snapshot
  isActive       Boolean  @default(true)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  category      Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  issued        CategoryIssuedCert[]

  @@unique([categoryId])
  @@index([categoryId])
  @@map("category_certificates")
}

// ============================================
// 11d. DOMAIN CERTIFICATES - Master Certificates for completing domains
// ============================================
model DomainCertificate {
  id              String   @id @default(uuid())
  domainId        String
  certificateName String   // e.g., "Master AI & Data Science Professional"
  description     String?  @db.Text
  requirements    Json?    // Stores requirements: { categories: [], domainCapstones: [] }
  templateData   Json?    // Template configuration snapshot
  isActive       Boolean  @default(true)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  domain  Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  issued  DomainIssuedCert[]

  @@unique([domainId])
  @@index([domainId])
  @@map("domain_certificates")
}

// ============================================
// 11e. CATEGORY ISSUED CERTIFICATES - Track issued category certificates
// ============================================
model CategoryIssuedCert {
  id                  String    @id @default(uuid())
  categoryCertificateId String
  userId              String
  certificateCode     String    @unique // e.g., "CAT-CERT-2026-XXXX"
  qrCode              String?   @db.Text
  pdfUrl              String?   @db.Text
  verificationUrl     String    @db.Text
  templateSnapshot    Json?    // Snapshot of certificate template at generation time
  issuedAt            DateTime  @default(now())
  revokedAt           DateTime?
  revokeReason        String?

  // Digital signatures
  ceoSignature        String?   @db.Text // CEO signature URL or data
  academicDirectorSignature String? @db.Text // Academic Director signature URL or data
  officialSeal        String?   @db.Text // Official seal URL or data

  // Status
  status              String    @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryCertificate CategoryCertificate @relation(fields: [categoryCertificateId], references: [id], onDelete: Cascade)

  @@unique([categoryCertificateId, userId])
  @@index([userId])
  @@index([categoryCertificateId])
  @@index([status])
  @@map("category_issued_certs")
}

// ============================================
// 11f. DOMAIN ISSUED CERTIFICATES - Track issued domain certificates
// ============================================
model DomainIssuedCert {
  id                 String    @id @default(uuid())
  domainCertificateId String
  userId             String
  certificateCode    String    @unique // e.g., "DOM-CERT-2026-XXXX"
  qrCode             String?   @db.Text
  pdfUrl             String?   @db.Text
  verificationUrl    String    @db.Text
  templateSnapshot   Json?     // Snapshot of certificate template at generation time
  issuedAt           DateTime  @default(now())
  revokedAt          DateTime?
  revokeReason       String?

  // Digital signatures
  ceoSignature        String?   @db.Text
  academicDirectorSignature String? @db.Text

  // Status
  status             String    @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  domainCertificate  DomainCertificate @relation(fields: [domainCertificateId], references: [id], onDelete: Cascade)

  @@unique([domainCertificateId, userId])
  @@index([userId])
  @@index([domainCertificateId])
  @@index([status])
  @@map("domain_issued_certs")
}

// ============================================
// 11g. CERTIFICATE PROGRESS - Track student progress toward certificates
// ============================================
model CertificateProgress {
  id                    String   @id @default(uuid())
  userId                String
  // For Category Certificates
  categoryCertificateId String?
  // For Domain Certificates
  domainCertificateId   String?
  
  // Progress tracking
  coursesCompleted      Int      @default(0)
  totalCourses         Int      @default(0)
  lessonsCompleted      Int      @default(0)
  totalLessons         Int      @default(0)
  exercisesCompleted    Int      @default(0)
  totalExercises       Int      @default(0)
  miniProjectsCompleted Int      @default(0)
  totalMiniProjects    Int      @default(0)
  capstonesCompleted   Int      @default(0)
  totalCapstones       Int      @default(0)
  
  // Progress percentages
  overallProgress       Int      @default(0) // 0-100
  
  // Detailed completion tracking
  completedCourseIds    String[] @default([])
  completedLessonIds    String[] @default([])
  completedExerciseIds  String[] @default([])
  completedMiniProjectIds String[] @default([])
  completedCapstoneIds  String[] @default([])
  earnedCategoryCertIds String[] @default([]) // For Domain certificates
  
  lastActivityAt       DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryCertificateId])
  @@unique([userId, domainCertificateId])
  @@index([userId])
  @@index([categoryCertificateId])
  @@index([domainCertificateId])
  @@map("certificate_progress")
}

// ============================================
// 11h. CERTIFICATE ELIGIBILITY - Track eligibility status
// ============================================
model CertificateEligibility {
  id                    String   @id @default(uuid())
  userId                String
  
  // Certificate type and ID
  certificateType       String   // 'CATEGORY' or 'DOMAIN'
  certificateId         String   // categoryCertificateId or domainCertificateId
  
  // Eligibility status
  isEligible            Boolean  @default(false)
  eligibilityCheckedAt  DateTime @default(now())
  lastCheckedAt         DateTime @default(now())
  
  // Requirements breakdown
  requirements          Json     // { courses: { required: X, completed: Y }, lessons: {...}, exercises: {...}, ... }
  
  // Eligibility triggers
  eligibleAt            DateTime? // When eligibility was achieved
  notifiedAt            DateTime? // When user was notified

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, certificateType, certificateId])
  @@index([userId])
  @@index([certificateType, certificateId])
  @@index([isEligible])
  @@map("certificate_eligibility")
}

// ============================================
// 12. PAYMENTS - Transaction records (Enhanced)
// ============================================

model Payment {
  id                  String    @id @default(uuid())
  userId              String
  type                String    @default("one_time") // one_time, subscription, category_purchase, domain_purchase, academy_purchase
  status              String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  
  // Amount details
  amount              Decimal
  currency            String    @default("NGN")
  amountInKobo         Int?      // For NGN payments
  amountInCents        Int?      // For USD payments
  
  // Paystack
  paystackReference   String?
  paystackRef         String?   // Alias for paystackReference
  paystackId          String?
  channel             String?
  paystackChannel     String?
  authorizationCode   String?
  paystackFees        Decimal?
  
  // Gateway response
  gatewayResponse     Json?
  
  // References for new purchase types
  categoryPurchaseId  String?
  domainPurchaseId    String?
  academyPurchaseId   String?
  
  // Metadata
  metadata            Json?
  
  // Timestamps
  initiatedAt         DateTime  @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  refundedAt          DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paystackRef])
  @@index([status])
  @@index([type])
  @@map("payments")
}

// ============================================
// 13. SUBSCRIPTIONS - Membership subscriptions (Legacy)
// ============================================

model Subscription {
  id                       String    @id @default(uuid())
  userId                   String
  planId                   String?
  planName                 String    @default("FREE") // FREE, PRO, TEAM (legacy)
  status                   String    @default("active") // active, cancelled, expired, trialing
  startDate                DateTime  @default(now())
  endDate                  DateTime?
  recurringPrice           Decimal?
  isPro                    Boolean   @default(false)
  autoRenew                Boolean   @default(true)
  paystackSubscriptionCode String?
  stripeSubscriptionId     String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("subscriptions")
}

// ============================================
// 14b. PRICING PLAN PURCHASE SCOPE
// ============================================
enum PurchaseScope {
  ACADEMY     // Full platform access
  DOMAIN      // All categories within specific domain(s)
  CATEGORY    // All courses within specific category(ies)
}

// ============================================
// HYBRID PRICING MODE
// ============================================
enum PricingMode {
  MANUAL          // Administrator manually enters every supported currency
  AUTO_CONVERSION // System auto-converts from a base currency
  HYBRID          // Auto-generated with manual override capability
}

model Plan {
  id                 String   @id @default(uuid())
  name               String
  description        String?  @db.Text
  planType           String   @default("subscription") // subscription, one_time
  billingCycle       String   @default("monthly") // monthly, yearly, lifetime
  
  // Purchase Scope - NEW FIELD
  purchaseScope      PurchaseScope @default(CATEGORY)
  
  // For Domain Scope - which domains this plan covers
  allowedDomainIds   String[] @default([])
  
  // For Category Scope - which categories this plan covers
  allowedCategoryIds String[] @default([])
  
  // Legacy fields
  price              Decimal  @default(0) // Legacy single price
  currency           String   @default("USD") // Legacy single currency
  pricing            Json? // Multi-currency: { "NGN": { "amount": 50000, "paystackPlanId": "xxx" }, "USD": { "amount": 100, "stripePriceId": "xxx" } }
  stripePriceId      String?  @unique // Legacy
  paystackPlanId     String?  @unique // Legacy
  features           Json?    @default("[]")
  isActive           Boolean  @default(true)
  isFeatured         Boolean  @default(false)
  discountPercentage Int?     @default(0) // For limited-time offers
  promoCode          String?
  maxCourses         Int?     @default(-1) // -1 for unlimited
  maxCertificates    Int?     @default(-1)
  trialDays          Int?     @default(0)
  sortOrder          Int      @default(0)
  
  // Multi-Currency Pricing Fields
  pricingMode        PricingMode @default(MANUAL)
  baseCurrency       String   @default("NGN") // Base currency for auto-conversion: NGN or USD
  supportedCurrencies String[] @default(["NGN"]) // ["NGN"], ["USD"], or ["NGN", "USD"]
  
  // Manual Prices
  ngnPrice           Decimal? @default(0) // Manual NGN price
  usdPrice           Decimal? @default(0) // Manual USD price
  
  // Auto-Generated Prices (from conversion)
  generatedNgnPrice  Decimal? // System-generated NGN price
  generatedUsdPrice  Decimal? // System-generated USD price
  
  // Exchange Rate Info
  exchangeRate       Decimal? @default(1) // Exchange rate used (e.g., 1650 for NGN to USD)
  exchangeRateSource String?  // Provider used for exchange rate
  exchangeRateTimestamp DateTime? // When the rate was fetched
  
  // Legacy Pricing JSON - enhanced structure:
  // {
  //   "NGN": { "manualAmount": 80000, "generatedAmount": 80000, "isManualOverride": true, "paystackPlanId": "xxx" },
  //   "USD": { "manualAmount": 49.99, "generatedAmount": 50.12, "isManualOverride": true, "stripePriceId": "xxx" }
  // }
  
  // Visual customization
  icon               String?
  bannerUrl          String?
  themeColor         String?
  
  // Status
  status             String   @default("PUBLISHED") // DRAFT, PUBLISHED, ARCHIVED
  visibility         String   @default("PUBLIC") // PUBLIC, PRIVATE
  isPopular          Boolean  @default(false)
  isRecommended      Boolean  @default(false)
  
  // SEO
  seoTitle           String?
  seoDescription     String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  subscriptions      Subscription[]
  categoryPurchases  CategoryPurchase[]
  domainPurchases    DomainPurchase[]
  academyPurchases   AcademyPurchase[]
  discountCampaigns  DiscountCampaign[]

  @@map("plans")
}

// ============================================
// 14c. CURRENCY SETTINGS - Platform-wide currency configuration
// ============================================
model CurrencySetting {
  id                  String   @id @default(uuid())
  currency            String   @unique // NGN, USD, etc.
  name                String   // Nigerian Naira, US Dollar, etc.
  symbol              String   // ₦, $, etc.
  code                String   // NGN, USD, etc.
  exchangeRate        Decimal  @default(1) // Rate relative to base currency
  isEnabled           Boolean  @default(true)
  isDefault           Boolean  @default(false)
  sortOrder           Int      @default(0)
  
  // Gateway Configuration
  gatewayProvider     String?  // paystack, stripe, flutterwave, paypal
  gatewayEnabled      Boolean  @default(false)
  gatewayConfig       Json?    // { apiKey, secret, etc. }
  
  // Display Settings
  decimalPlaces       Int      @default(2)
  thousandsSeparator  String   @default(",")
  decimalSeparator    String   @default(".")
  symbolPosition      String   @default("before") // before or after
  
  // Exchange Rate Settings
  exchangeRateProvider String? // fixer, openexchangerates, exchangerate-api
  lastRateUpdate      DateTime?
  autoUpdateRates     Boolean  @default(false)
  updateIntervalHours Int      @default(24)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@map("currency_settings")
}

// ============================================
// PAYMENT GATEWAY MODELS
// ============================================

// Payment Gateway - Defines available payment providers
model PaymentGateway {
  id              String   @id @default(uuid())
  name            String   @unique // Paystack, Stripe, Flutterwave, etc.
  provider        String   // paystack, stripe, flutterwave, paypal, razorpay, bank_transfer, manual, crypto
  slug            String   @unique
  
  // Status
  isEnabled       Boolean  @default(false)
  isDefault       Boolean  @default(false)
  environment     String   @default("sandbox") // sandbox, production
  
  // Configuration
  logoUrl         String?
  iconName        String?  // Lucide icon name
  color           String?  // Hex color for UI
  
  // API Credentials (encrypted)
  publicKey       String?  // Public/API key
  secretKey       String?  // Secret key (encrypted)
  webhookSecret   String?  // Webhook verification secret
  
  // Gateway-specific settings
  supportedCurrencies String[] // ["NGN", "USD", "GBP", etc.]
  supportedCountries  String[] // ["NG", "US", "GB", etc.]
  supportedMethods    String[] // ["card", "bank_transfer", "ussd", "mobile_money", "bank"]
  
  // Fees
  transactionFeePercent Decimal @default(0) // Percentage fee
  transactionFeeFixed   Decimal @default(0) // Fixed fee per transaction
  currency             String   @default("USD") // Fee currency
  
  // Priority (lower = higher priority)
  priority         Int      @default(100)
  
  // Health monitoring
  lastHealthCheck DateTime?
  healthStatus    String   @default("unknown") // healthy, degraded, down, unknown
  healthMessage   String?
  
  // Notes
  notes           String?
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  configurations  GatewayConfiguration[]
  transactions    PaymentTransaction[]
  logs            PaymentGatewayLog[]
  
  @@map("payment_gateways")
}

// Gateway Configuration per Country/Currency
model GatewayConfiguration {
  id              String   @id @default(uuid())
  gatewayId       String
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  
  // Country & Currency
  country         String   // ISO country code (NG, US, GB)
  countryName     String   // Full country name
  currency        String   // ISO currency code (NGN, USD, GBP)
  
  // Configuration
  isEnabled       Boolean  @default(true)
  priority        Int      @default(100) // Priority for this country/gateway combo
  
  // Gateway-specific config (JSON)
  config          Json?    // Additional gateway-specific settings
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([gatewayId, country, currency])
  @@map("gateway_configurations")
}

// Payment Transaction - Tracks all payment transactions
model PaymentTransaction {
  id              String   @id @default(uuid())
  
  // Gateway
  gatewayId       String
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id])
  
  // References
  reference       String   @unique // Our internal reference
  gatewayRef      String?  // Gateway's transaction reference
  userId          String?
  
  // Amount
  amount          Decimal
  currency        String   // NGN, USD, etc.
  amountInBase   Decimal? // Amount in base currency
  
  // Exchange Rate
  exchangeRate    Decimal  @default(1)
  
  // Status
  status          String   @default("pending") // pending, processing, success, failed, cancelled, refunded
  
  // Purchase Type
  purchaseType    String   // membership, category, domain, academy, course, certificate
  purchaseId      String?  // ID of the purchased item
  
  // Metadata
  metadata        Json?
  
  // Response
  gatewayResponse Json?
  
  // Payment Method
  paymentMethod   String?  // card, bank_transfer, ussd, mobile_money
  
  // Customer
  customerEmail   String?
  customerName    String?
  
  // Fees
  processingFee   Decimal  @default(0)
  platformFee     Decimal  @default(0)
  
  // Timeline
  initiatedAt     DateTime @default(now())
  completedAt     DateTime?
  failedAt       DateTime?
  
  // IP & User Agent
  ipAddress       String?
  userAgent       String?
  
  // Error
  errorMessage    String?
  errorCode       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([gatewayId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_transactions")
}

// Payment Gateway Log - For monitoring and debugging
model PaymentGatewayLog {
  id              String   @id @default(uuid())
  gatewayId       String
  gateway PaymentGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  
  // Transaction
  transactionId   String?
  
  // Log details
  logType         String   // request, response, webhook, error, health_check
  level           String   @default("info") // debug, info, warn, error
  
  // Content
  method          String?  // HTTP method
  endpoint        String?
  requestBody     Json?
  responseBody    Json?
  responseStatus  Int?
  responseTime    Int?     // milliseconds
  
  // Error
  errorMessage    String?
  errorStack      String?
  
  // IP
  ipAddress       String?
  
  createdAt       DateTime @default(now())
  
  @@index([gatewayId])
  @@index([transactionId])
  @@index([logType])
  @@index([createdAt])
  @@map("payment_gateway_logs")
}

// Exchange Rate - For manual exchange rate management
model ExchangeRate {
  id              String   @id @default(uuid())
  fromCurrency    String   // Source currency
  toCurrency      String   // Target currency
  
  rate            Decimal
  isAutomatic     Boolean  @default(false)
  provider        String?  // fixer, manual, etc.
  
  validFrom       DateTime @default(now())
  validUntil      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

// Payment Settings - Global payment configuration
model PaymentSettings {
  id              String   @id @default(uuid())
  
  // Default Gateway
  defaultGatewayId String?
  
  // Currency Settings
  defaultCurrency String   @default("USD")
  supportedCurrencies String[] // ["NGN", "USD", "GBP"]
  
  // Exchange Rates
  exchangeRateMode String  @default("automatic") // automatic, manual
  autoUpdateRates  Boolean @default(true)
  updateIntervalHours Int @default(24)
  
  // Transaction Settings
  paymentTimeout  Int      @default(30) // minutes
  retryAttempts  Int      @default(3)
  
  // Refund Settings
  refundEnabled  Boolean  @default(true)
  refundWindowDays Int    @default(7)
  
  // Webhook Settings
  webhookEnabled Boolean  @default(true)
  webhookRetries Int      @default(3)
  
  // Invoice Settings
  invoicePrefix  String   @default("INV")
  invoiceAutoNumber Boolean @default(true)
  
  // Receipt Settings
  receiptEnabled Boolean  @default(true)
  receiptEmailEnabled Boolean @default(true)
  
  // Tax Settings
  taxEnabled     Boolean  @default(false)
  taxRate        Decimal  @default(0)
  taxName        String   @default("Tax")
  
  // Platform Fee
  platformFeePercent Decimal @default(0)
  platformFeeFixed   Decimal @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("payment_settings")
}

// ============================================
// 14d. CATEGORY PURCHASE - One-time purchase for category access
// ============================================
model CategoryPurchase {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?   // Optional - which plan was used
  categoryId      String
  categoryName    String    // Denormalized for quick access
  domainId        String?   // Domain this category belongs to
  domainName      String?   // Denormalized
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt       DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id])
  
  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("category_purchases")
}

// ============================================
// 14d. DOMAIN PURCHASE - One-time purchase for domain access (all categories)
// ============================================
model DomainPurchase {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?   // Optional - which plan was used
  domainId        String
  domainName      String    // Denormalized for quick access
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt      DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef    String?
  
  updatedAt       DateTime  @updatedAt

  plan  Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  domain Domain  @relation(fields: [domainId], references: [id])
  
  @@unique([userId, domainId])
  @@index([userId])
  @@index([domainId])
  @@index([status])
  @@map("domain_purchases")
}

// ============================================
// 14e. ACADEMY PURCHASE - One-time purchase for entire platform access
// ============================================
model AcademyPurchase {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?   // Optional - which plan was used
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt      DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef    String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  @@unique([userId])
  @@index([userId])
  @@index([status])
  @@map("academy_purchases")
}
// ============================================
model Invoice {
  id              String    @id @default(uuid())
  invoiceNumber   String    @unique // INV-2024-00001
  
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userEmail       String
  items           Json      // [{ description, quantity, unitPrice, total, planId, scope }]
  
  // Totals
  subtotal        Decimal   @default(0)
  discountAmount  Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  currency        String    @default("USD")
  
  // Status
  status          String    @default("draft") // draft, issued, paid, cancelled, refunded
  dueDate         DateTime?
  paidAt          DateTime?
  
  // Payment
  paymentId       String?
  
  // References
  couponId        String?
  couponCode      String?
  
  // Address
  billingAddress  Json?
  
  // Notes
  notes           String?
  terms           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

// ============================================
// 14h. COUPON - Discount codes
// ============================================
model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  
  // Discount type
  discountType    String    // percentage, fixed_amount
  discountValue   Decimal   // Percentage (0-100) or fixed amount
  
  // Currency for fixed discounts
  currency        String    @default("USD")
  
  // Limits
  maxUses         Int?      // Null = unlimited
  currentUses     Int       @default(0)
  maxUsesPerUser  Int       @default(1)
  
  // Validity
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  
  // Scope - which plans/products this applies to
  applicableScope String    @default("all") // all, academy, domain, category, specific_plan
  applicablePlanIds String[] @default([]) // If specific_plan
  applicableDomainIds String[] @default([])
  applicableCategoryIds String[] @default([])
  
  // Status
  isActive        Boolean   @default(true)
  isPublic        Boolean   @default(true) // Public vs admin-only
  
  // Requirements
  minPurchaseAmount Decimal?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  discountCampaigns DiscountCampaign[]
  
  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// ============================================
// 14i. DISCOUNT CAMPAIGN - Time-limited offers
// ============================================
model DiscountCampaign {
  id              String    @id @default(uuid())
  name            String
  description     String?
  
  // Discount
  discountType    String    // percentage, fixed_amount
  discountValue   Decimal
  currency        String    @default("USD")
  
  // Target
  targetType      String    // all, specific_plan, domain, category
  planId          String?
  domainId        String?
  categoryId      String?
  
  // Validity
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  
  // Coupon association (optional - some campaigns need code)
  couponId        String?
  couponCode      String?
  requiresCoupon  Boolean   @default(false)
  
  // Display
  displayBanner   Boolean   @default(true)
  bannerText      String?
  bannerColor     String?
  
  // Limits
  maxRedemptions Int?      // Null = unlimited
  currentRedemptions Int   @default(0)
  
  // Status
  isActive        Boolean   @default(true)
  
  // Priority (for stacking with other discounts)
  priority        Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan Plan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  coupon Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  
  @@index([isActive])
  @@index([startsAt, endsAt])
  @@map("discount_campaigns")
}

// ============================================
// 14j. ACCESS LICENSE - Granular access control
// ============================================
model AccessLicense {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseType     String    // academy, domain, category, course
  targetId        String    // domainId, categoryId, or courseId depending on type
  
  // Status
  status          String    @default("active") // active, expired, revoked
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?
  
  // Source
  sourceType      String    // purchase, admin_grant, trial, subscription
  purchaseId      String?   // Reference to CategoryPurchase, DomainPurchase, or AcademyPurchase
  grantedByAdminId String?  // If admin granted access
  
  // Auto-enrollment tracking
  coursesEnrolled Int       @default(0)
  lastEnrolledAt  DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, licenseType, targetId])
  @@index([userId])
  @@index([licenseType, targetId])
  @@index([status])
  @@map("access_licenses")
}

// ============================================
// 15. LEARNING PATHS - Course roadmaps
// ============================================

model LearningPath {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  subtitle         String?
  description      String?  @db.Text
  thumbnailUrl     String?
  difficultyLevel  String   @default("beginner") // beginner, intermediate, advanced
  estimatedHours   Int?     // Total estimated hours
  isActive         Boolean  @default(true) // Admin toggle for visibility
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pathCourses  LearningPathCourse[]
  userProgress LearningPathProgress[]

  @@map("learning_paths")
}

// ============================================
// 15. LEARNING PATH COURSES - Junction table
// ============================================

model LearningPathCourse {
  id             String   @id @default(uuid())
  learningPathId String
  courseId       String
  orderIndex     Int      @default(0)
  isRequired     Boolean  @default(true)
  stepTitle      String?  // e.g., "Step 1: HTML/CSS"
  createdAt      DateTime @default(now())

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([learningPathId, courseId])
  @@map("learning_path_courses")
}

// ============================================
// 16. LEARNING PATH PROGRESS - User progress
// ============================================

model LearningPathProgress {
  id              String    @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPathId  String
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  progressPercent Int       @default(0)

  learningPath LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
  @@map("learning_path_progress")
}

// ============================================
// 17. WISHLISTS - Saved courses
// ============================================

model Wishlist {
  id       String   @id @default(uuid())
  userId   String
  courseId String
  addedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("wishlists")
}

// ============================================
// 18. NOTIFICATIONS - User alerts
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info") // info, success, warning, error
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// 19. AUDIT LOGS - Activity tracking
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String // SELECT, INSERT, UPDATE, DELETE, EXPORT, etc.
  module       String // STORAGE, DB_EXPLORER, USERS, etc.
  targetTable  String? // Table being accessed
  targetId     String? // Specific row ID
  query        String?  @db.Text // Query executed
  affectedRows Int? // Number of rows affected
  previousData Json? // For UPDATE/DELETE - stores original data
  newData      Json? // For INSERT/UPDATE - stores new data
  details      Json?
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indexes for fast querying
  @@index([createdAt])
  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([targetTable])
  @@map("audit_logs")
}

// ============================================
// 20. SUPPORT TICKETS - Help requests
// ============================================

model SupportTicket {
  id         String    @id @default(uuid())
  userId     String?
  email      String
  category   String // billing, course-access, technical, business, partnership, other
  subject    String?
  message    String    @db.Text
  status     String    @default("open") // open, in_progress, resolved, closed
  priority   String    @default("medium") // low, medium, high, urgent
  assignedTo String?
  labels     String? // Comma-separated labels for categorization
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  comments TicketComment[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([userId])
  @@index([assignedTo])
  @@map("support_tickets")
}

// ============================================
// 21. TICKET COMMENTS - Support replies
// ============================================

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String?
  message    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("ticket_comments")
}

// ============================================
// 22. NEWSLETTER SUBSCRIBERS
// ============================================

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

// ============================================
// 23. NEWSLETTER CAMPAIGNS
// ============================================

model NewsletterCampaign {
  id                String    @id @default(uuid())
  title             String
  subject           String
  content           String    @db.Text // HTML content
  status            String    @default("draft") // draft, scheduled, sending, sent, failed
  recipientType     String    @default("all") // all, subscribers, enrolled, course_specific
  recipientCourseId String?
  scheduledAt       DateTime?
  sentAt            DateTime?
  totalRecipients   Int       @default(0)
  successfulSends   Int       @default(0)
  failedSends       Int       @default(0)
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("newsletter_campaigns")
}

// ============================================
// 25. STORED FILES - File management
// ============================================

model StoredFile {
  id             String    @id @default(uuid())
  originalName   String
  storedName     String    @unique
  fileUrl        String    @unique
  fileSize       Int // in bytes
  mimeType       String
  fileType       String // IMAGE, VIDEO, AUDIO, DOCUMENT, ARCHIVE, OTHER
  storageType    String    @default("local") // local, s3, cloudinary
  folder         String? // virtual folder path
  tags           String[]  @default([])
  courseId       String? // optional association
  uploadedBy     String?
  isOrphaned     Boolean   @default(false) // not linked to any resource
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("stored_files")
}

// ============================================
// 26. SYSTEM SETTINGS
// ============================================

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  category    String   @default("general") // general, appearance, integrations, security, email, payments, storage
  description String? // Human-readable description
  isPublic    Boolean  @default(false) // Accessible without auth
  isEncrypted Boolean  @default(false) // Encrypt value in DB
  validation  Json? // Validation rules: { required: true, pattern: "...", min: 0, max: 100 }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

// ============================================
// 27. ROLES - Role-based access control
// ============================================

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // SUPER_ADMIN, ADMIN, CONTENT_MANAGER, SUPPORT_STAFF, STUDENT
  displayName String
  description String?
  isSystem    Boolean      @default(false) // System roles cannot be deleted
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  UserRole    UserRole[]
  
  // Portal default roles
  defaultPortals Portal[]
  
  // Staff assignment roles
  staffAssignments StaffAssignment[]

  @@map("roles")
}

// ============================================
// 28. PERMISSIONS - Permission definitions
// ============================================

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // MANAGE_USERS, VIEW_ANALYTICS, EDIT_COURSES, etc.
  displayName String
  description String?
  resource    String // The resource category (users, courses, settings, etc.)
  action      String // The action type (create, read, update, delete, manage)
  roles       Role[]
  createdAt   DateTime @default(now())

  @@unique([resource, action])
  @@map("permissions")
}

// ============================================
// 29. USER ROLE ASSIGNMENTS - Junction table
// ============================================

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

// ============================================
// 30. FORUM THREADS - Community discussions
// ============================================

model ForumThread {
  id          String        @id @default(uuid())
  title       String
  content     String        @db.Text
  category    String        @default("general") // general, course-help, announcements, off-topic
  authorId    String
  isActive    Boolean       @default(true) // Admin toggle for visibility
  isPinned    Boolean       @default(false)
  isResolved  Boolean       @default(false)
  viewCount   Int           @default(0)
  replyCount  Int           @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies ForumReply[]

  @@index([category])
  @@index([authorId])
  @@index([createdAt])
  @@index([isPinned])
  @@map("forum_threads")
}

// ============================================
// 31. FORUM REPLIES - Thread responses
// ============================================

model ForumReply {
  id        String      @id @default(uuid())
  content   String      @db.Text
  authorId  String
  threadId  String
  isActive    Boolean    @default(true) // Admin toggle for visibility
  isAccepted Boolean    @default(false) // Marked as accepted answer
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
  @@map("forum_replies")
}

// ============================================
// MCCS MODELS - Master Course Creation System
// ============================================

// ============================================
// 32. COURSE LEARNING OUTCOMES
// ============================================
model CourseLearningOutcome {
  id          String   @id @default(uuid())
  courseId    String
  outcome     String   @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_learning_outcomes")
}

// ============================================
// 33. COURSE OBJECTIVES
// ============================================
model CourseObjective {
  id          String   @id @default(uuid())
  courseId    String
  objective   String   @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_objectives")
}

// ============================================
// 34. COURSE RESOURCES
// ============================================
model CourseResource {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  type        String   // document, link, download, external
  url         String
  fileType    String?
  fileSize    Int?
  isDownloadable Boolean @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_resources")
}

// ============================================
// 35. COURSE SOFTWARE REQUIREMENTS
// ============================================
model CourseSoftware {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  version     String?
  url         String?  // Download URL
  description String?  @db.Text
  isRequired  Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_software")
}

// ============================================
// 36. COURSE DATASETS
// ============================================
model CourseDataset {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  description String?  @db.Text
  sourceUrl   String?
  fileUrl     String?
  fileType    String?
  fileSize    Int?
  isDownloadable Boolean @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_datasets")
}

// ============================================
// 37. COURSE PREREQUISITES
// ============================================
model Prerequisite {
  id            String   @id @default(uuid())
  courseId      String
  title         String
  description   String?  @db.Text
  type          String   @default("course") // course, skill, certification
  externalUrl   String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("prerequisites")
}

// ============================================
// 38. CAREER OUTCOMES
// ============================================
model CareerOutcome {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  icon        String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("career_outcomes")
}

// ============================================
// 39. INSTRUCTORS
// ============================================
model Instructor {
  id          String   @id @default(uuid())
  userId      String?  // Optional link to User
  name        String
  title       String?
  bio         String?  @db.Text
  avatarUrl   String?
  expertise   String[] // Areas of expertise
  socialLinks Json?    // { linkedin, twitter, website }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("instructors")
}

// ============================================
// 40. PRACTICAL EXERCISES (Per Lesson)
// ============================================
model PracticalExercise {
  id                String   @id @default(uuid())
  lessonId          String   @unique
  instructions      String?  @db.Text // Markdown instructions
  starterCode       String?  @db.Text
  solutionCode      String?  @db.Text
  hints             Json?    // Array of hint strings
  rubric            Json?    // { criteria: [{ name, points, description }] }
  maxScore          Int      @default(100)
  passingScore      Int      @default(70)
  timeLimit         Int?     // In minutes
  isRequired        Boolean  @default(false)
  allowRetry        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("practical_exercises")
}

// ============================================
// 41. MINI PROJECTS (Per Course)
// ============================================
model MiniProject {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  description     String?  @db.Text
  scenario        String?  @db.Text // Real-world scenario
  workflow        String?  @db.Text // Step-by-step workflow
  deliverables    Json?    // { required: [...], optional: [...] }
  evaluationRubric Json?   // { criteria: [...] }
  starterFilesUrl String?
  solutionFilesUrl String?
  maxScore        Int      @default(100)
  passingScore    Int      @default(70)
  isRequired      Boolean  @default(false)
  dueDaysAfterStart Int?   // Due X days after course enrollment
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  projectSubmissions ProjectSubmission[]

  @@index([courseId])
  @@map("mini_projects")
}

// ============================================
// 42. DIFFICULTY LEVEL CAPSTONES
// ============================================
model DifficultyLevelCapstone {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  difficultyLevel String   // BEGINNER, INTERMEDIATE, ADVANCED
  includedCourses Json?    // Array of course IDs
  orderIndex      Int      @default(0)
  isPublished     Boolean  @default(false)
  thumbnailUrl    String?
  certificateTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments     CapstoneEnrollment[]

  @@index([difficultyLevel])
  @@index([isPublished])
  @@map("difficulty_level_caps")
}

// ============================================
// 43. PROFESSIONAL CAPSTONES
// ============================================
model ProfessionalCapstone {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  description     String?  @db.Text
  categoryId      String?
  includedCourses Json?    // Array of course IDs
  requirements    String?  @db.Text
  deliverables    Json?    // { required: [...] }
  evaluationCriteria Json? // { criteria: [...] }
  orderIndex      Int      @default(0)
  isPublished     Boolean  @default(false)
  thumbnailUrl    String?
  certificateTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollments     CapstoneEnrollment[]

  @@index([categoryId])
  @@index([isPublished])
  @@map("professional_caps")
}

// ============================================
// 44. CAPSTONE ENROLLMENTS
// ============================================
model CapstoneEnrollment {
  id                    String   @id @default(uuid())
  userId                String
  difficultyCapstoneId   String?
  professionalCapstoneId String?
  progressPercent       Int      @default(0)
  status                String   @default("not_started") // not_started, in_progress, submitted, graded
  submittedAt           DateTime?
  grade                 Int?
  feedback              String?  @db.Text
  certificateId         String?
  enrolledAt            DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  difficultyCapstone    DifficultyLevelCapstone? @relation(fields: [difficultyCapstoneId], references: [id], onDelete: SetNull)
  professionalCapstone  ProfessionalCapstone? @relation(fields: [professionalCapstoneId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([difficultyCapstoneId])
  @@index([professionalCapstoneId])
  @@map("capstone_enrollments")
}

// ============================================
// 45. COURSE SEO SETTINGS
// ============================================
model CourseSEO {
  id            String   @id @default(uuid())
  courseId      String   @unique
  metaTitle     String?
  metaDescription String?
  keywords      String[]
  ogImage       String?
  canonicalUrl  String?
  noIndex       Boolean  @default(false)
  noFollow      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_seo")
}

// ============================================
// 46. COURSE VERSIONING
// ============================================
model CourseVersion {
  id          String   @id @default(uuid())
  courseId    String
  version     Int
  changes     String?  @db.Text
  createdBy   String?
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, version])
  @@index([courseId])
  @@map("course_versions")
}

// ============================================
// 47. PROJECT SUBMISSIONS (Student Project Hub)
// ============================================
model ProjectSubmission {
  id              String   @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String?
  miniProjectId   String?
  capstoneId      String?  // Can be difficulty or professional capstone ID
  capstoneType    String?  // 'difficulty' or 'professional'
  
  // Submission Details
  title           String
  description     String?  @db.Text
  submissionUrl   String?  // GitHub repo or live link
  fileUrls        Json?    // Array of uploaded file URLs
  screenshots     Json?    // Array of screenshot URLs
  
  // Enhanced Status
  status          String   @default("DRAFT") // DRAFT, SUBMITTED, UNDER_REVIEW, REVISION_REQUIRED, RESUBMITTED, APPROVED, REJECTED, COMPLETED, ARCHIVED
  isLocked        Boolean  @default(false) // Lock after submission unless revision required
  isDeleted       Boolean  @default(false) // Soft delete
  
  // Project type for filtering
  projectType     String   @default("MINI_PROJECT") // PRACTICAL_EXERCISE, MINI_PROJECT, DIFFICULTY_CAPSTONE, PROFESSIONAL_CAPSTONE
  
  // Grading
  grade           Int?
  gradeType       String?  // PERCENTAGE, POINTS, PASS_FAIL, LETTER
  rubricId        String?  // Which rubric was used
  rubricScore     Decimal? @default(0) // Total score from rubric
  maxScore        Decimal? @default(100)
  
  // Legacy feedback
  feedback        String?  @db.Text
  submittedAt     DateTime?
  gradedAt        DateTime?
  
  // MCCS Link
  isFromMCCS      Boolean  @default(false) // Was this imported from MCCS
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  miniProject     MiniProject? @relation(fields: [miniProjectId], references: [id], onDelete: SetNull)
  
  // New relations
  versions        SubmissionVersion[]
  reviews         ProjectReview[]
  statusHistory   ProjectStatusHistory[]
  comments        ProjectComment[]
  assignments     ReviewerAssignment[]
  
  // Staff Management Relations
  supervisorMilestones SupervisorMilestone[]

  @@index([userId])
  @@index([courseId])
  @@index([miniProjectId])
  @@index([status])
  @@index([capstoneType])
  @@index([projectType])
  @@map("project_submissions")
}

// ============================================
// 48. PORTFOLIO ENTRIES (Student Project Vault)
// ============================================
model PortfolioEntry {
  id              String   @id @default(uuid())
  userId          String
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Project Details
  title           String
  description     String?  @db.Text
  liveUrl         String?
  githubUrl       String?
  demoVideoUrl    String?
  
  // Tech Stack
  techStack       String[] // Tags like React, PostgreSQL, etc.
  
  // Media
  screenshots     Json?    // Array of screenshot URLs
  demoVideo       String?  // URL to demo video
  
  // Project Rationale
  rationale       String?  @db.Text
  
  // Privacy & Safety
  visibility      String   @default("PRIVATE") // PRIVATE, PUBLIC, ACADEMY_ONLY
  publicSlug     String?  @unique // Public URL slug: /portfolio/{slug}
  
  // MCCS Link (optional import)
  linkedCourseId   String?
  linkedMiniProjectId String?
  linkedCapstoneId   String?
  
  // Status
  isPublished     Boolean  @default(false)
  viewCount        Int       @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([visibility])
  @@index([publicSlug])
  @@map("portfolio_entries")
}

// ============================================
// 49. PROJECT SUBMISSION STATUS HISTORY
// ============================================
model ProjectStatusHistory {
  id              String    @id @default(uuid())
  submissionId    String
  previousStatus  String?
  newStatus       String
  changedBy       String    // userId of who made the change
  reason          String?   @db.Text
  createdAt       DateTime  @default(now())

  submission      ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("project_status_history")
}

// ============================================
// 50. PROJECT RUBRIC
// ============================================
model ProjectRubric {
  id              String    @id @default(uuid())
  name            String
  description     String?   @db.Text
  
  // Rubric type
  type            String    @default("MINI_PROJECT") // MINI_PROJECT, DIFFICULTY_CAPSTONE, PROFESSIONAL_CAPSTONE, PRACTICAL_EXERCISE
  courseId        String?   // Optional - link to specific course
  difficultyLevel String?   // BEGINNER, INTERMEDIATE, ADVANCED
  
  // Criteria stored as JSON
  criteria        Json      // [{ name: string, description: string, weight: number, maxPoints: number }]
  
  // Status
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false) // Default rubric for this type
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  scores          ProjectScore[]

  @@map("project_rubrics")
}

// ============================================
// 51. PROJECT SUBMISSION VERSION
// ============================================
model SubmissionVersion {
  id              String    @id @default(uuid())
  submissionId    String
  versionNumber   Int       // 1, 2, 3, etc.
  
  // Submission details for this version
  title           String
  description     String?   @db.Text
  submissionUrl   String?   // GitHub/GitLab/Bitbucket URL
  demoUrl         String?   // Live demo URL
  reportUrl       String?   // PDF/DOCX report URL
  videoUrl        String?   // Video presentation URL
  fileUrls        Json?     // Array of uploaded file URLs
  screenshots     Json?     // Array of screenshot URLs
  additionalLinks Json?     // Any additional URLs
  notes           String?   @db.Text
  
  // Version metadata
  isLatest        Boolean   @default(false)
  submittedAt     DateTime  @default(now())
  
  createdAt       DateTime  @default(now())

  submission      ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, versionNumber])
  @@index([submissionId])
  @@map("submission_versions")
}

// ============================================
// 52. PROJECT REVIEW
// ============================================
model ProjectReview {
  id              String    @id @default(uuid())
  submissionId    String
  versionId       String?   // Which version is being reviewed
  
  // Reviewer info
  reviewerId      String    // Admin or Instructor userId
  
  // Review decision
  decision        String    // APPROVED, REJECTED, REVISION_REQUIRED, UNDER_REVIEW
  
  // Overall feedback
  overallFeedback String?   @db.Text
  
  // Review metadata
  reviewedAt      DateTime  @default(now())
  isLatest        Boolean   @default(true)
  
  // Time tracking
  timeSpentMinutes Int?     // Time spent on review
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submission      ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  feedback        ProjectFeedback[]
  scores          ProjectScore[]
  reviewer        User      @relation("Reviewer", fields: [reviewerId], references: [id])

  @@index([submissionId])
  @@index([reviewerId])
  @@map("project_reviews")
}

// ============================================
// 53. PROJECT FEEDBACK
// ============================================
model ProjectFeedback {
  id              String    @id @default(uuid())
  reviewId       String
  category        String    // TECHNICAL, CODE_QUALITY, DOCUMENTATION, INNOVATION, PRESENTATION, GENERAL
  
  // Feedback content
  title           String?
  content         String    @db.Text
  recommendation  String?   @db.Text // RECOMMENDED, NEEDS_IMPROVEMENT, CRITICAL
  
  // Line/item reference (optional)
  referenceType   String?   // FILE, LINE, SCREENSHOT, SECTION
  referenceId     String?
  referenceDetail String?
  
  createdAt       DateTime  @default(now())

  review          ProjectReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([category])
  @@map("project_feedback")
}

// ============================================
// 54. PROJECT SCORE
// ============================================
model ProjectScore {
  id              String    @id @default(uuid())
  reviewId        String
  rubricId        String
  rubric          ProjectRubric @relation(fields: [rubricId], references: [id])
  
  // Score details
  criteriaName    String    // Name from rubric criteria
  pointsAwarded   Decimal   @default(0)
  maxPoints       Decimal
  
  // Feedback for this criteria
  feedback        String?   @db.Text
  
  createdAt       DateTime  @default(now())

  review          ProjectReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, rubricId, criteriaName])
  @@index([reviewId])
  @@map("project_scores")
}

// ============================================
// 55. REVIEWER ASSIGNMENT
// ============================================
model ReviewerAssignment {
  id              String    @id @default(uuid())
  submissionId    String
  submission      ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  // Assigned reviewer
  reviewerId      String
  reviewer        User      @relation(fields: [reviewerId], references: [id])
  
  // Assignment details
  assignedAt      DateTime  @default(now())
  assignedBy      String?   // userId of admin who made assignment
  dueDate         DateTime?
  
  // Status
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  
  // Completion
  completedAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([submissionId, reviewerId])
  @@index([reviewerId])
  @@index([status])
  @@map("reviewer_assignments")
}

// ============================================
// 56. PROJECT COMMENT THREAD
// ============================================
model ProjectComment {
  id              String    @id @default(uuid())
  submissionId    String
  submission      ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  // Author
  authorId        String
  author          User      @relation(fields: [authorId], references: [id])
  
  // Content
  content         String    @db.Text
  isInternal      Boolean   @default(false) // Internal comments only visible to staff
  
  // Reference (optional)
  referenceType   String?   // FILE, SCREENSHOT, LINE
  referenceId     String?
  
  // Threading
  parentId        String?
  parent          ProjectComment? @relation("CommentThread", fields: [parentId], references: [id])
  replies         ProjectComment[] @relation("CommentThread")
  
  // Status
  isResolved      Boolean   @default(false)
  resolvedBy      String?
  resolvedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([submissionId])
  @@index([authorId])
  @@index([parentId])
  @@map("project_comments")
}

// =============================================================================
// ENTERPRISE STAFF MANAGEMENT MODELS
// =============================================================================

// ============================================
// STAFF PROFILE - Extended profile for staff members
// ============================================
model StaffProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Professional Information
  staffId         String?  // Internal staff ID
  title           String?  // Job title
  department      String?  // Department
  employeeType    String?  // FULL_TIME, PART_TIME, CONTRACTOR, CONSULTANT
  
  // Contact Information
  phone           String?
  phoneAlt        String?
  address         String?
  city            String?
  country         String?
  
  // Emergency Contact
  emergencyName   String?
  emergencyPhone  String?
  emergencyEmail  String?
  emergencyRelation String?
  
  // Additional Info
  dateOfBirth     DateTime?
  gender          String?
  nationality     String?
  
  // Employment Details
  hireDate       DateTime?
  terminationDate DateTime?
  
  // Government IDs
  idType          String?  // PASSPORT, NATIONAL_ID, DRIVERS_LICENSE
  idNumber        String?
  idDocumentUrl   String?
  
  // Banking (for payroll)
  bankName        String?
  bankAccount     String?
  bankRouting     String?
  
  // Profile Photo (override from Profile if needed)
  staffAvatarUrl  String?
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  assignments     StaffAssignment[]
  sessions        StaffSession[]
  activities      StaffActivity[]
  supervisorAssignments ProjectSupervisor[]
  notifications   StaffNotification[]
  
  @@index([userId])
  @@index([department])
  @@index([isActive])
  @@map("staff_profiles")
}

// ============================================
// PORTAL - Portal types for different staff roles
// ============================================
model Portal {
  id              String   @id @default(uuid())
  name            String   @unique // SUPER_ADMIN, ADMIN, ACADEMIC_DIRECTOR, INSTRUCTOR, REVIEWER, PROJECT_SUPERVISOR, FINANCE_OFFICER, ADMISSION_OFFICER, STUDENT_AFFAIRS, QUALITY_ASSURANCE, RESEARCH_COORDINATOR, SUPPORT_STAFF
  displayName     String
  description     String?  @db.Text
  icon            String?  // Icon name
  color           String?  // Hex color
  
  // Access Control
  isActive        Boolean  @default(true)
  isSystem        Boolean  @default(false) // System portals cannot be deleted
  
  // Role Assignment
  defaultRoleId   String?
  defaultRole     Role?    @relation(fields: [defaultRoleId], references: [id])
  
  // Dashboard Configuration
  dashboardRoute  String?  // Default route after login
  
  // Permissions Configuration
  allowedPermissions Json? // JSON array of permission names
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  staffAssignments StaffAssignment[]
  
  @@index([name])
  @@index([isActive])
  @@map("portals")
}

// ============================================
// STAFF ASSIGNMENT - Domain/Category/Course assignments for staff
// ============================================
model StaffAssignment {
  id              String   @id @default(uuid())
  staffProfileId  String
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  
  // Portal Reference
  portalId        String
  portal          Portal   @relation(fields: [portalId], references: [id])
  
  // Role Reference
  roleId          String?
  role            Role?    @relation(fields: [roleId], references: [id])
  
  // Hierarchy Assignment - Academy -> Domain -> Category -> Difficulty -> Course
  domainId        String?  // Top-level domain
  categoryId      String?  // Category within domain
  difficultyLevel String?  // BEGINNER, INTERMEDIATE, ADVANCED
  courseId        String?  // Specific course
  
  // Relations
  domain          Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  course          Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  // Assignment Details
  isPrimary       Boolean   @default(false) // Primary assignment for this domain/category
  assignedAt      DateTime  @default(now())
  assignedBy      String?   // userId of super admin who made assignment
  expiresAt       DateTime? // Optional expiration
  
  // Status
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE, EXPIRED
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([staffProfileId])
  @@index([portalId])
  @@index([domainId])
  @@index([categoryId])
  @@index([courseId])
  @@index([status])
  @@map("staff_assignments")
}

// ============================================
// STAFF SESSION - Active session tracking for security
// ============================================
model StaffSession {
  id              String   @id @default(uuid())
  staffProfileId  String
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  
  // Session Details
  sessionToken    String   @unique
  ipAddress       String?
  userAgent       String?
  browser         String?
  browserVersion  String?
  os              String?
  deviceType      String?  // DESKTOP, MOBILE, TABLET
  
  // Location
  country         String?
  city            String?
  latitude        Float?
  longitude       Float?
  
  // Timestamps
  createdAt       DateTime @default(now())
  lastActiveAt    DateTime @default(now())
  expiresAt       DateTime
  
  // Status
  isActive        Boolean  @default(true)
  terminatedAt    DateTime?
  terminatedBy    String?  // userId who terminated the session
  terminationReason String? // ADMIN_TERMINATED, LOGOUT, EXPIRED, SECURITY
  
  // Security
  failedAttempts  Int      @default(0)
  lastFailedAt   DateTime?
  
  @@index([staffProfileId])
  @@index([sessionToken])
  @@index([isActive])
  @@index([createdAt])
  @@map("staff_sessions")
}

// ============================================
// STAFF ACTIVITY - Complete activity timeline for audit
// ============================================
model StaffActivity {
  id              String   @id @default(uuid())
  staffProfileId  String
  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  
  // Activity Details
  action          String   // ACCOUNT_CREATED, ROLE_ASSIGNED, PORTAL_ENABLED, PASSWORD_CHANGED, LOGIN, LOGOUT, PROJECT_ASSIGNED, COURSE_ASSIGNED, REVIEW_COMPLETED, CERTIFICATE_APPROVED, SUSPENDED, REACTIVATED
  category        String   // ACCOUNT, ROLE, PORTAL, SECURITY, ASSIGNMENT, PROJECT, COURSE, REVIEW, CERTIFICATE, SYSTEM
  description     String   @db.Text
  
  // Context
  targetType      String?  // The type of entity affected
  targetId        String?  // The ID of the entity affected
  targetName      String?  // Human-readable name of the entity
  
  // Metadata
  metadata        Json?    // Additional context data
  
  // Actor (who performed the action)
  performedBy     String?  // userId of who performed the action (null if self)
  performedByName String?  // Name of who performed the action
  
  // Timestamps
  createdAt       DateTime @default(now())
  
  @@index([staffProfileId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
  @@map("staff_activities")
}

// ============================================
// PROJECT SUPERVISOR - Supervisor assignments for projects
// ============================================
model ProjectSupervisor {
  id              String   @id @default(uuid())
  
  // Supervisor Reference
  supervisorId    String
  supervisorProfile StaffProfile @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  
  // Assignment Level - can be at domain, category, difficulty, or course level
  domainId        String?
  categoryId      String?
  difficultyLevel String?
  courseId        String?
  
  // Relations
  domain          Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  course          Course?   @relation(fields: [courseId], references: [id], onDelete: SetNull)
  
  // Assignment Details
  isPrimary       Boolean   @default(false)
  maxStudents     Int?      // Maximum students supervised
  currentStudents Int       @default(0)
  
  // Status
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  
  // Assignment Info
  assignedAt      DateTime  @default(now())
  assignedBy      String?   // userId of super admin
  expiresAt       DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  milestones      SupervisorMilestone[]
  
  @@index([supervisorId])
  @@index([domainId])
  @@index([categoryId])
  @@index([courseId])
  @@index([status])
  @@map("project_supervisors")
}

// ============================================
// SUPERVISOR MILESTONE - Milestone tracking for supervised projects
// ============================================
model SupervisorMilestone {
  id              String    @id @default(uuid())
  supervisorId    String
  supervisor      ProjectSupervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  
  // Milestone Details
  submissionId    String
  submission       ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  
  // Milestone Info
  milestoneName   String    // Proposal, Literature Review, Methodology, etc.
  milestoneOrder  Int       @default(0)
  
  // Status
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, SUBMITTED, APPROVED, REVISION_REQUESTED
  
  // Approval
  isApproved      Boolean   @default(false)
  approvedAt      DateTime?
  approvedBy      String?   // supervisorId
  feedback        String?   @db.Text
  
  // Submission
  submittedAt     DateTime?
  submissionNotes String?  @db.Text
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([supervisorId, submissionId, milestoneName])
  @@index([supervisorId])
  @@index([submissionId])
  @@index([status])
  @@map("supervisor_milestones")
}

// ============================================
// STAFF NOTIFICATION - Notifications for staff members
// ============================================
model StaffNotification {
  id              String   @id @default(uuid())
  
  // Recipient
  staffProfileId  String
  staffProfile   StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)
  
  // Notification Content
  title           String
  message         String   @db.Text
  type            String   // ACCOUNT, ASSIGNMENT, PROJECT, REVIEW, COURSE, SYSTEM, SECURITY
  
  // Action
  actionUrl       String?
  actionLabel     String?
  
  // Status
  isRead          Boolean  @default(false)
  readAt          DateTime?
  
  // Priority
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  
  // Metadata
  metadata        Json?    // Additional data
  
  createdAt       DateTime @default(now())
  
  @@index([staffProfileId])
  @@index([isRead])
  @@index([createdAt])
  @@map("staff_notifications")
}

// Note: Additional relations to User and ProjectSubmission models are added via field declarations above

// ============================================
// SCHOLARSHIP TYPES - Configurable scholarship type definitions
// ============================================
model ScholarshipType {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  color       String?
  isActive    Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  scholarships Scholarship[]

  @@map("scholarship_types")
}

// ============================================
// SCHOLARSHIP PROGRAM - Main scholarship program entity
// ============================================
model Scholarship {
  id              String   @id @default(uuid())

  // Basic Info
  name            String
  shortName       String?
  slug            String   @unique
  description     String?  @db.Text
  objectives      String?  @db.Text
  eligibility     String?  @db.Text
  benefits        String?  @db.Text

  // Type
  typeId          String
  type            ScholarshipType @relation(fields: [typeId], references: [id])

  // Financial
  awardAmount     Decimal? @db.Decimal(12, 2)
  currency        String   @default("USD")
  coverageType    String   @default("PARTIAL") // FULL, PARTIAL, TUITION_WAIVER, FINANCIAL_AID
  maxRecipients   Int?
  currentRecipients Int    @default(0)

  // Budget
  totalBudget     Decimal? @db.Decimal(12, 2)
  budgetUsed      Decimal? @db.Decimal(12, 2) @default(0)

  // Dates
  openingDate     DateTime?
  closingDate     DateTime?
  announcementDate DateTime?
  startDate       DateTime?
  endDate         DateTime?

  // Status
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, CLOSED, ARCHIVED
  visibility      String   @default("PUBLIC") // PUBLIC, PRIVATE, FEATURED
  isFeatured      Boolean  @default(false)
  allowLateApplications Boolean @default(false)

  // Selection
  selectionMethod String   @default("COMMITTEE") // COMMITTEE, AUTOMATIC, INTERVIEW, COMBINED

  // Sponsor
  sponsorId       String?
  sponsor         Sponsor? @relation(fields: [sponsorId], references: [id])

  // SEO
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?

  // Media
  bannerUrl       String?
  thumbnailUrl    String?
  icon            String?
  color           String?

  // Requirements
  requiredDocuments Json?   @default("[]") // Array of required document types
  minGPA           Decimal? @db.Decimal(4, 2)
  requiredDocumentsList String? @db.Text // Detailed document requirements

  // Academic Requirements
  applicableDomains    String?  // JSON array of domain IDs
  applicableCategories String?  // JSON array of category IDs
  applicableDifficulties String? // JSON array of difficulty levels

  // Eligibility Criteria
  nationality      String?   // Any, Specific countries
  eligibleCountries String? @db.Text
  gender           String?   // Any, Male, Female, Other
  minAge           Int?
  maxAge           Int?
  educationLevel   String?   // High School, Undergraduate, Graduate, PhD, Any
  requiredCertifications String? @db.Text

  // Review Configuration
  requireInterview Boolean   @default(false)
  interviewDate    DateTime?
  interviewLocation String?

  // Auto-enrollment Configuration
  autoEnroll      Boolean   @default(false)
  autoGrantMembership Boolean @default(false)
  membershipPlan   String?
  autoGrantDomainAccess Boolean @default(false)
  autoGrantCategoryAccess Boolean @default(false)

  //timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?
  closedAt        DateTime?

  // Relations
  applications    ScholarshipApplication[]
  reviewRubric    ScholarshipReviewRubric?
  awards          ScholarshipAward[]
  customQuestions ScholarshipCustomQuestion[]

  @@index([slug])
  @@index([status])
  @@index([visibility])
  @@index([typeId])
  @@index([sponsorId])
  @@index([closingDate])
  @@map("scholarships")
}

// ============================================
// SCHOLARSHIP SPONSOR - Organizations/individuals sponsoring scholarships
// ============================================
model Sponsor {
  id              String   @id @default(uuid())

  // Basic Info
  name            String
  shortName       String?
  slug            String   @unique
  type            String   // COMPANY, NGO, FOUNDATION, GOVERNMENT, INDIVIDUAL, ISLAMIC_ORG
  logoUrl         String?
  website         String?
  description     String?  @db.Text

  // Contact
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  address         String?

  // Financial
  totalContributed Decimal? @db.Decimal(12, 2) @default(0)
  currency        String   @default("USD")

  // Status
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  isVerified      Boolean  @default(false)

  // Branding
  bannerColor     String?
  tagline         String?

  // Terms
  agreementUrl    String?
  terms           String?  @db.Text

  // Notification Preferences
  receiveReports  Boolean  @default(true)
  reportFrequency String   @default("MONTHLY") // WEEKLY, MONTHLY, QUARTERLY

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  scholarships    Scholarship[]
  scholarshipsSponsored ScholarshipAward[]
  userId          String?   // User account for sponsor portal access
  User            User?     @relation(fields: [userId], references: [id])

  @@index([slug])
  @@index([type])
  @@index([status])
  @@map("sponsors")
}

// ============================================
// SCHOLARSHIP APPLICATION - Individual scholarship applications
// ============================================
model ScholarshipApplication {
  id              String   @id @default(uuid())

  // Reference
  applicationNumber String @unique
  trackingNumber   String @unique

  // Scholarship
  scholarshipId   String
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id])

  // Applicant Info (can apply without existing account)
  email           String
  firstName       String
  lastName        String
  phone           String?
  dateOfBirth     DateTime?

  // Personal Info
  nationality     String?
  country         String?
  state           String?
  city            String?
  address         String?
  postalCode      String?
  gender          String?

  // Education
  educationLevel  String?
  institution     String?
  fieldOfStudy    String?
  graduationYear  Int?
  gpa             Decimal? @db.Decimal(4, 2)
  academicBackground String? @db.Text

  // Professional
  employmentStatus String?
  currentEmployer String?
  jobTitle        String?

  // Additional Info
  researchInterests String? @db.Text
  linkedIn        String?
  github          String?
  googleScholar    String?
  orcid           String?

  // Financial Need
  financialNeedStatement String? @db.Text
  householdIncome  Decimal? @db.Decimal(12, 2)
  hasScholarshipDependency Boolean @default(false)

  // Essays
  statementOfPurpose String? @db.Text
  motivationLetter   String? @db.Text
  communityImpactStatement String? @db.Text

  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRelation String?

  // Status
  status          String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, INTERVIEW, ADDITIONAL_INFO, APPROVED, REJECTED, WITHDRAWN
  submittedAt     DateTime @default(now())
  lastStatusChange DateTime @default(now())
  statusNotes     String?  @db.Text

  // Review
  assignedReviewerId String?
  reviewerNotes   String?  @db.Text
  reviewScore     Decimal? @db.Decimal(5, 2)
  reviewerRecommendation String? // APPROVE, REJECT, MORE_INFO
  reviewedAt      DateTime?

  // Interview
  interviewScheduledAt DateTime?
  interviewNotes  String?  @db.Text
  interviewScore  Decimal? @db.Decimal(5, 2)

  // Documents
  documents       Json?    @default("[]") // Array of document URLs and types

  // Draft
  isDraft         Boolean  @default(false)
  draftData       Json?    // Saved draft application data

  // User (if they have an account)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  // Auto-created account
  autoCreatedUserId String?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  reviews         ScholarshipApplicationReview[]
  statusHistory   ScholarshipApplicationStatus[]
  notifications   ScholarshipNotification[]
  award          ScholarshipAward?

  @@index([applicationNumber])
  @@index([trackingNumber])
  @@index([email])
  @@index([scholarshipId])
  @@index([status])
  @@index([userId])
  @@index([submittedAt])
  @@map("scholarship_applications")
}

// ============================================
// APPLICATION STATUS HISTORY - Track status changes
// ============================================
model ScholarshipApplicationStatus {
  id              String   @id @default(uuid())
  applicationId   String
  application     ScholarshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  status          String
  notes           String?  @db.Text
  changedBy       String?  // userId or 'SYSTEM'
  changedAt       DateTime @default(now())

  @@index([applicationId])
  @@map("scholarship_application_status")
}

// ============================================
// SCHOLARSHIP APPLICATION REVIEW - Individual review entries
// ============================================
model ScholarshipApplicationReview {
  id              String   @id @default(uuid())
  applicationId   String
  application     ScholarshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  reviewerId      String
  reviewer        User     @relation(fields: [reviewerId], references: [id])

  // Scores
  academicExcellence Decimal? @db.Decimal(5, 2)
  researchPotential   Decimal? @db.Decimal(5, 2)
  leadership          Decimal? @db.Decimal(5, 2)
  financialNeed        Decimal? @db.Decimal(5, 2)
  innovation           Decimal? @db.Decimal(5, 2)
  communication        Decimal? @db.Decimal(5, 2)
  communityImpact      Decimal? @db.Decimal(5, 2)
  totalScore          Decimal? @db.Decimal(5, 2)

  // Feedback
  recommendation  String?  // APPROVE, REJECT, MORE_INFO
  comments        String?  @db.Text
  strengths       String?  @db.Text
  weaknesses      String?  @db.Text

  // Review Rubric
  rubricId        String?
  rubric          ScholarshipReviewRubric? @relation(fields: [rubricId], references: [id])
  criteriaScores  Json?    // Dynamic rubric criteria scores

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([applicationId])
  @@index([reviewerId])
  @@map("scholarship_application_reviews")
}

// ============================================
// REVIEW RUBRIC - Scoring rubrics for scholarship reviews
// ============================================
model ScholarshipReviewRubric {
  id              String   @id @default(uuid())

  name            String
  description     String?  @db.Text
  scholarshipId   String?  @unique
  scholarship     Scholarship? @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  // Criteria
  criteria        Json     // Array of { name, description, maxScore, weight }

  // Configuration
  passingScore    Decimal  @db.Decimal(5, 2) @default(0)
  isDefault       Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  reviews         ScholarshipApplicationReview[]

  @@map("scholarship_review_rubrics")
}

// ============================================
// CUSTOM APPLICATION QUESTIONS - Dynamic questions for applications
// ============================================
model ScholarshipCustomQuestion {
  id              String   @id @default(uuid())

  scholarshipId   String
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  question        String
  questionType    String   // TEXT, TEXTAREA, NUMBER, DATE, SELECT, MULTISELECT, FILE, CHECKBOX
  description     String?

  // Options (for select/multiselect)
  options         Json?    // Array of { value, label }

  // Validation
  isRequired      Boolean  @default(false)
  minLength       Int?
  maxLength       Int?
  minValue        Decimal?
  maxValue        Decimal?
  allowedFileTypes String? // Comma-separated file extensions
  maxFileSize     Int?     // In MB

  // Order
  orderIndex      Int      @default(0)

  // Conditional Logic
  dependsOn       String?  // Question ID this depends on
  showIfValue     Json?    // Value that triggers this question

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scholarshipId])
  @@map("scholarship_custom_questions")
}

// ============================================
// SCHOLARSHIP AWARD - Awarded scholarships to recipients
// ============================================
model ScholarshipAward {
  id              String   @id @default(uuid())

  // Reference
  awardNumber     String   @unique

  // Scholarship
  scholarshipId   String
  scholarship     Scholarship @relation(fields: [scholarshipId], references: [id])

  // Application
  applicationId   String   @unique
  application     ScholarshipApplication @relation(fields: [applicationId], references: [id])

  // Recipient
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  email           String
  firstName       String
  lastName        String

  // Award Details
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  coverageType    String   // FULL, PARTIAL, TUITION_WAIVER, FINANCIAL_AID

  // Duration
  startDate       DateTime
  endDate         DateTime?
  durationMonths  Int?

  // Status
  status          String   @default("PENDING_ACCEPTANCE") // PENDING_ACCEPTANCE, ACTIVE, COMPLETED, CANCELLED, SUSPENDED, EXPIRED

  // Acceptance
  acceptanceDeadline DateTime?
  acceptedAt      DateTime?
  declinedAt      DateTime?
  declineReason   String?

  // Documents
  awardLetterUrl  String?
  certificateUrl  String?

  // Payment
  paymentStatus   String   @default("PENDING") // PENDING, PROCESSING, PAID, CANCELLED
  paymentDate     DateTime?
  paymentReference String?

  // Sponsor Tracking
  sponsorId       String?
  sponsor         Sponsor? @relation(fields: [sponsorId], references: [id])

  // Notes
  notes           String?  @db.Text

  // Approved By
  approvedBy      String?  // userId
  approvedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  notifications   ScholarshipNotification[]

  @@index([awardNumber])
  @@index([scholarshipId])
  @@index([userId])
  @@index([status])
  @@index([sponsorId])
  @@map("scholarship_awards")
}

// ============================================
// SCHOLARSHIP NOTIFICATION - Notifications for scholarship events
// ============================================
model ScholarshipNotification {
  id              String   @id @default(uuid())

  applicationId   String?
  application     ScholarshipApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  awardId         String?
  scholarshipAward ScholarshipAward? @relation(fields: [awardId], references: [id], onDelete: Cascade)

  recipientEmail  String
  recipientName   String?

  // Notification Content
  type            String   // APPLICATION_SUBMITTED, APPLICATION_RECEIVED, UNDER_REVIEW, INTERVIEW_SCHEDULED, ADDITIONAL_INFO, APPROVED, REJECTED, AWARD_ISSUED, ENROLLMENT_COMPLETED
  title           String
  message         String   @db.Text

  // Delivery
  emailSent       Boolean  @default(false)
  emailSentAt     DateTime?
  emailError      String?

  inAppSent       Boolean  @default(false)
  inAppRead       Boolean  @default(false)

  // Metadata
  metadata        Json?

  createdAt       DateTime @default(now())

  @@index([applicationId])
  @@index([awardId])
  @@index([recipientEmail])
  @@index([type])
  @@map("scholarship_notifications")
}

// ============================================
// FINANCIAL AID - Need-based financial assistance records
// ============================================
model FinancialAid {
  id              String   @id @default(uuid())

  // Reference
  aidNumber       String   @unique

  // User
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  // Type
  type            String   // TUITION_REDUCTION, PAYMENT_PLAN, BURSARY, WORK_STUDY, EMERGENCY_FUND
  category        String?  // NEED_BASED, MERIT, DISABILITY, MILITARY, etc.

  // Amount
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")

  // Duration
  startTerm       String?  // e.g., "Fall 2024"
  endTerm         String?
  durationMonths  Int?

  // Terms
  requirements    String?  @db.Text
  conditions      String?  @db.Text
  gpaRequirement  Decimal? @db.Decimal(4, 2)
  enrollmentRequirement Int? // Minimum credits/hours

  // Status
  status          String   @default("ACTIVE") // PENDING, ACTIVE, COMPLETED, CANCELLED, SUSPENDED
  effectiveDate   DateTime
  endDate         DateTime?

  // Payment
  disbursementSchedule Json? // Payment schedule
  disbursedAmount  Decimal? @db.Decimal(12, 2) @default(0)
  lastDisbursement DateTime?
  nextDisbursement DateTime?

  // Approval
  approvedBy      String?
  approvedAt      DateTime?
  denialReason    String?

  // Notes
  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([aidNumber])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("financial_aids")
}

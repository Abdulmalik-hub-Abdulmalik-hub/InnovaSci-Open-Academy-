generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USERS - Only Admin and Student roles
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  role          String    @default("STUDENT") // SUPER_ADMIN, ADMIN, STUDENT
  status        String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile              Profile?
  enrollments          Enrollment[]
  certificates         Certificate[]
  payments             Payment[]
  notifications        Notification[]
  wishlists            Wishlist[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  learningProgress     LearningProgress[]
  userLectureProgress  UserLectureProgress[]
  learningPathProgress LearningPathProgress[]
  supportTickets       SupportTicket[]
  ticketComments       TicketComment[]
  userRoles            UserRole[]
  Role                 Role?                  @relation(fields: [roleId], references: [id])
  roleId               String?
  IssuedCertificate    IssuedCertificate[]
  forumThreads         ForumThread[]
  forumReplies         ForumReply[]
  instructors          Instructor[]
  capstoneEnrollments  CapstoneEnrollment[]
  projectSubmissions   ProjectSubmission[]
  portfolioEntries     PortfolioEntry[]
  
  // New Certificate Relations
  categoryIssuedCerts    CategoryIssuedCert[]
  domainIssuedCerts     DomainIssuedCert[]
  certificateProgress    CertificateProgress[]
  certificateEligibility CertificateEligibility[]

  // Purchase Relations
  categoryPurchases  CategoryPurchase[]
  domainPurchases    DomainPurchase[]
  academyPurchases   AcademyPurchase[]
  invoices           Invoice[]
  accessLicenses     AccessLicense[]

  @@map("users")
}

// ============================================
// 2. PROFILES - User details
// ============================================

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String?
  username    String?  @unique
  phone       String?
  country     String?
  city        String?
  gender      String?
  bio         String?
  avatarUrl   String?
  status      String   @default("active")
  preferences Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// 3. DOMAINS - Top-level academic domains
// ============================================

model Domain {
  id              String   @id @default(uuid())
  name            String   @unique
  shortName       String?
  slug            String   @unique
  shortDescription String? @db.Text
  fullDescription String? @db.Text
  thumbnailUrl    String?
  bannerUrl       String?
  icon            String?  // Icon name or emoji
  color           String?  // Hex color code
  orderIndex      Int      @default(0)
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  visibility      String   @default("PUBLIC") // PUBLIC, PRIVATE, FEATURED
  isFeatured      Boolean  @default(false)
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  categories Category[]
  domainCertificates DomainCertificate[]

  @@index([slug])
  @@index([status])
  @@index([visibility])
  @@index([isFeatured])
  @@map("domains")
}

// ============================================
// 4. CATEGORIES - Dynamic course categories (belongs to Domain)
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String
  description String?  @db.Text
  icon        String?  // Icon name or emoji
  thumbnailUrl String?
  bannerUrl   String?
  color       String?  // Hex color code
  orderIndex  Int      @default(0)
  isActive    Boolean  @default(true)
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  visibility  String   @default("PUBLIC") // PUBLIC, PRIVATE
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  domainId String?
  domain   Domain? @relation(fields: [domainId], references: [id], onDelete: SetNull)
  courses  Course[]
  categoryCertificate CategoryCertificate?

  @@unique([domainId, slug])
  @@unique([domainId, name])
  @@index([domainId])
  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// 4. COURSES - Content managed by Admin
// ============================================

model Course {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  categoryId       String?  // Foreign key to Category
  subcategory      String?
  shortDescription String?
  fullDescription  String?  @db.Text
  learningOutcomes String?  @db.Text
  prerequisites    String?  @db.Text
  targetAudience   String?
  difficultyLevel  String?
  language         String   @default("English")
  durationHours    Int?
  thumbnailUrl     String?
  promoVideoUrl    String?
  introVideoUrl    String?  // Introduction video for course landing page (mandatory)
  price            Decimal  @default(0) // Legacy single price
  pricing          Json? // Multi-currency: { "NGN": { "amount": 50000 }, "USD": { "amount": 100 } }
  isFree           Boolean  @default(true)
  isActive         Boolean  @default(true) // Admin toggle for visibility
  status           String   @default("draft") // draft, published, archived
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Certificate Template
  certificateTemplateId  String? // Reference to certificate template
  certificateTemplateUrl String? // Legacy URL field

  // MCCS Fields
  instructorId     String?
  whatYouWillLearn Json?  // Array of strings
  requirements     Json?  // Array of strings

  // Relations
  category         Category? @relation(fields: [categoryId], references: [id])
  instructor       Instructor? @relation(fields: [instructorId], references: [id])
  modules          Module[]
  lessons          Lesson[]
  enrollments      Enrollment[]
  certificates     Certificate[]
  wishlists        Wishlist[]
  learningProgress LearningProgress[]
  
  // Certificate Template Relation
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id])

  // Learning Paths
  learningPaths     LearningPathCourse[]
  IssuedCertificate IssuedCertificate[]

  // MCCS Relations
  courseLearningOutcomes CourseLearningOutcome[]
  objectives           CourseObjective[]
  resources            CourseResource[]
  software             CourseSoftware[]
  datasets             CourseDataset[]
  prerequisites_       Prerequisite[]
  careerOutcomes       CareerOutcome[]
  seo                  CourseSEO?
  versions             CourseVersion[]
  miniProjects         MiniProject[]
  projectSubmissions   ProjectSubmission[]

  @@map("courses")
}

// ============================================
// 4. MODULES - Course sections
// ============================================

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, orderIndex])
  @@map("modules")
}

// ============================================
// 5. LESSONS - Course content
// ============================================

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  moduleId    String?
  title       String
  description String?  @db.Text
  orderIndex  Int      @default(0)
  lessonType  String   @default("video") // video, reading, exercise
  duration    Int? // Duration in seconds
  videoUrl    String?
  isPreview   Boolean  @default(false)
  isFree      Boolean  @default(false) // Free lessons are accessible without enrollment
  isActive    Boolean  @default(true) // Admin toggle for visibility
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Exercise-specific fields
  isExercise          Boolean  @default(false) // Mark this as an exercise/project lesson
  exerciseDescription String?  @db.Text // Markdown description with instructions
  exerciseFilesUrl    String? // URL to downloadable starter files
  solutionVideoUrl    String? // URL to solution walkthrough video

  course          Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module          Module?               @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  materials       Material[]
  videos          Video[]
  progress        LearningProgress[]
  lectureProgress UserLectureProgress[]
  practicalExercise PracticalExercise?

  @@map("lessons")
}

// ============================================
// 6. MATERIALS - Lesson attachments
// ============================================

model Material {
  id              String   @id @default(uuid())
  lessonId        String
  title           String
  type            String?
  fileUrl         String
  visibility      String   @default("public")
  downloadAllowed Boolean  @default(true)
  createdAt       DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("materials")
}

// ============================================
// 7. VIDEOS - Lesson video content
// ============================================

model Video {
  id          String   @id @default(uuid())
  lessonId    String
  title       String
  videoUrl    String
  duration    Int?
  provider    String?
  storageType String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("videos")
}

// ============================================
// 8. ENROLLMENTS - Student course access
// ============================================

model Enrollment {
  id              String    @id @default(uuid())
  userId          String
  courseId        String
  progressPercent Int       @default(0)
  completed       Boolean   @default(false)
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ============================================
// 9. LEARNING PROGRESS - Lesson completion
// ============================================

model LearningProgress {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  lessonId    String
  completed   Boolean   @default(false)
  watchTime   Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("learning_progress")
}

// ============================================
// 10. USER LECTURE PROGRESS - Detailed tracking
// ============================================

model UserLectureProgress {
  id           String    @id @default(uuid())
  userId       String
  lessonId     String
  courseId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?
  watchTime    Int       @default(0)
  lastPosition Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@map("user_lecture_progress")
}

// ============================================
// 11. CERTIFICATES - Course completion certificates
// ============================================

model Certificate {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  certificateUrl   String?  @db.Text // Legacy field, use IssuedCertificate for new records
  pdfUrl           String?  @db.Text // URL to PDF in cloud storage
  verificationUrl  String?  @db.Text // Public verification URL
  verificationCode String   @unique
  issuedAt         DateTime @default(now())
  status           String   @default("ACTIVE") // ACTIVE, REVOKED

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("certificates")
}

// ============================================
// 11a. CERTIFICATE TEMPLATES - Configurable certificate layouts (ENHANCED)
// ============================================

model CertificateTemplate {
  id           String   @id @default(uuid())
  name         String   // Template name (e.g., "Standard Certificate", "Premium Certificate")
  description  String?  // Template description
  type         String   @default("COURSE") // COURSE, CATEGORY, DOMAIN
  backgroundUrl String  @db.Text // URL to template background image
  width        Int      @default(1200) // Template width in pixels
  height       Int      @default(900) // Template height in pixels
  
  // Field positions (as percentages of template dimensions for responsive rendering)
  studentNameX     Float   @default(0.5) // X position as percentage (0-1)
  studentNameY     Float   @default(0.35) // Y position as percentage (0-1)
  studentNameSize  Int     @default(48) // Font size in pixels
  studentNameFont  String  @default("Georgia") // Font family
  
  courseNameX      Float   @default(0.5)
  courseNameY      Float   @default(0.5)
  courseNameSize   Int     @default(32)
  courseNameFont   String  @default("Georgia")
  
  issueDateX       Float   @default(0.5)
  issueDateY       Float   @default(0.65)
  issueDateSize    Int     @default(24)
  issueDateFont    String  @default("Georgia")
  
  certificateIdX   Float   @default(0.5)
  certificateIdY  Float   @default(0.75)
  certificateIdSize Int    @default(18)
  certificateIdFont String @default("Courier")
  
  // Additional fields for category/domain certificates
  domainNameX           Float?
  domainNameY           Float?
  domainNameSize        Int?
  domainNameFont        String?
  
  categoryNameX         Float?
  categoryNameY         Float?
  categoryNameSize      Int?
  categoryNameFont      String?
  
  certificateTypeX      Float?
  certificateTypeY      Float?
  certificateTypeSize   Int?
  certificateTypeFont   String?
  
  // Signatures
  ceoSignatureX         Float?
  ceoSignatureY         Float?
  ceoSignatureWidth     Int?
  ceoSignatureHeight    Int?
  
  academicDirectorSignatureX     Float?
  academicDirectorSignatureY     Float?
  academicDirectorSignatureWidth Int?
  academicDirectorSignatureHeight Int?
  
  // Official seal
  officialSealX        Float?
  officialSealY        Float?
  officialSealWidth   Int?
  officialSealHeight  Int?
  
  // Styling
  textColor      String   @default("#1a1a2e") // Dark navy color for text
  
  // Status
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  courses Course[]

  @@map("certificate_templates")
}

// ============================================
// 11b. ISSUED CERTIFICATES - Certificate issuance tracking
// ============================================

model IssuedCertificate {
  id              String    @id @default(uuid())
  certificateId   String    @unique // Links to Certificate.id
  studentId       String
  courseId        String
  certificateCode String    @unique // Human-readable code (CERT-2026-XXXX)
  pdfUrl          String?   @db.Text // URL to generated PDF
  verificationUrl String    @db.Text // Public verification URL
  
  // Template snapshot for historical consistency
  // Stores the template configuration at the time of certificate generation
  templateSnapshot Json?    // Snapshot of CertificateTemplate at generation time (stored as JSON)
  
  issuedAt        DateTime  @default(now())
  revokedAt       DateTime?
  revokeReason    String?

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@index([issuedAt])
  @@map("issued_certificates")
}

// ============================================
// 11c. CATEGORY CERTIFICATES - Professional Certificates for completing categories
// ============================================
model CategoryCertificate {
  id              String   @id @default(uuid())
  categoryId      String
  certificateName String   // e.g., "Professional Data Science Certificate"
  description     String?  @db.Text
  requirements    Json?    // Stores requirements: { courses: [], difficultyCapstones: [], professionalCapstone: true }
  templateData   Json?    // Template configuration snapshot
  isActive       Boolean  @default(true)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  category      Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  issued        CategoryIssuedCert[]

  @@unique([categoryId])
  @@index([categoryId])
  @@map("category_certificates")
}

// ============================================
// 11d. DOMAIN CERTIFICATES - Master Certificates for completing domains
// ============================================
model DomainCertificate {
  id              String   @id @default(uuid())
  domainId        String
  certificateName String   // e.g., "Master AI & Data Science Professional"
  description     String?  @db.Text
  requirements    Json?    // Stores requirements: { categories: [], domainCapstones: [] }
  templateData   Json?    // Template configuration snapshot
  isActive       Boolean  @default(true)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  domain  Domain                  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  issued  DomainIssuedCert[]

  @@unique([domainId])
  @@index([domainId])
  @@map("domain_certificates")
}

// ============================================
// 11e. CATEGORY ISSUED CERTIFICATES - Track issued category certificates
// ============================================
model CategoryIssuedCert {
  id                  String    @id @default(uuid())
  categoryCertificateId String
  userId              String
  certificateCode     String    @unique // e.g., "CAT-CERT-2026-XXXX"
  qrCode              String?   @db.Text
  pdfUrl              String?   @db.Text
  verificationUrl     String    @db.Text
  templateSnapshot    Json?    // Snapshot of certificate template at generation time
  issuedAt            DateTime  @default(now())
  revokedAt           DateTime?
  revokeReason        String?

  // Digital signatures
  ceoSignature        String?   @db.Text // CEO signature URL or data
  academicDirectorSignature String? @db.Text // Academic Director signature URL or data
  officialSeal        String?   @db.Text // Official seal URL or data

  // Status
  status              String    @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryCertificate CategoryCertificate @relation(fields: [categoryCertificateId], references: [id], onDelete: Cascade)

  @@unique([categoryCertificateId, userId])
  @@index([userId])
  @@index([categoryCertificateId])
  @@index([status])
  @@map("category_issued_certs")
}

// ============================================
// 11f. DOMAIN ISSUED CERTIFICATES - Track issued domain certificates
// ============================================
model DomainIssuedCert {
  id                 String    @id @default(uuid())
  domainCertificateId String
  userId             String
  certificateCode    String    @unique // e.g., "DOM-CERT-2026-XXXX"
  qrCode             String?   @db.Text
  pdfUrl             String?   @db.Text
  verificationUrl    String    @db.Text
  templateSnapshot   Json?     // Snapshot of certificate template at generation time
  issuedAt           DateTime  @default(now())
  revokedAt          DateTime?
  revokeReason       String?

  // Digital signatures
  ceoSignature        String?   @db.Text
  academicDirectorSignature String? @db.Text

  // Status
  status             String    @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  domainCertificate  DomainCertificate @relation(fields: [domainCertificateId], references: [id], onDelete: Cascade)

  @@unique([domainCertificateId, userId])
  @@index([userId])
  @@index([domainCertificateId])
  @@index([status])
  @@map("domain_issued_certs")
}

// ============================================
// 11g. CERTIFICATE PROGRESS - Track student progress toward certificates
// ============================================
model CertificateProgress {
  id                    String   @id @default(uuid())
  userId                String
  // For Category Certificates
  categoryCertificateId String?
  // For Domain Certificates
  domainCertificateId   String?
  
  // Progress tracking
  coursesCompleted      Int      @default(0)
  totalCourses         Int      @default(0)
  lessonsCompleted      Int      @default(0)
  totalLessons         Int      @default(0)
  exercisesCompleted    Int      @default(0)
  totalExercises       Int      @default(0)
  miniProjectsCompleted Int      @default(0)
  totalMiniProjects    Int      @default(0)
  capstonesCompleted   Int      @default(0)
  totalCapstones       Int      @default(0)
  
  // Progress percentages
  overallProgress       Int      @default(0) // 0-100
  
  // Detailed completion tracking
  completedCourseIds    String[] @default([])
  completedLessonIds    String[] @default([])
  completedExerciseIds  String[] @default([])
  completedMiniProjectIds String[] @default([])
  completedCapstoneIds  String[] @default([])
  earnedCategoryCertIds String[] @default([]) // For Domain certificates
  
  lastActivityAt       DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryCertificateId])
  @@unique([userId, domainCertificateId])
  @@index([userId])
  @@index([categoryCertificateId])
  @@index([domainCertificateId])
  @@map("certificate_progress")
}

// ============================================
// 11h. CERTIFICATE ELIGIBILITY - Track eligibility status
// ============================================
model CertificateEligibility {
  id                    String   @id @default(uuid())
  userId                String
  
  // Certificate type and ID
  certificateType       String   // 'CATEGORY' or 'DOMAIN'
  certificateId         String   // categoryCertificateId or domainCertificateId
  
  // Eligibility status
  isEligible            Boolean  @default(false)
  eligibilityCheckedAt  DateTime @default(now())
  lastCheckedAt         DateTime @default(now())
  
  // Requirements breakdown
  requirements          Json     // { courses: { required: X, completed: Y }, lessons: {...}, exercises: {...}, ... }
  
  // Eligibility triggers
  eligibleAt            DateTime? // When eligibility was achieved
  notifiedAt            DateTime? // When user was notified

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, certificateType, certificateId])
  @@index([userId])
  @@index([certificateType, certificateId])
  @@index([isEligible])
  @@map("certificate_eligibility")
}

// ============================================
// 12. PAYMENTS - Transaction records (Enhanced)
// ============================================

model Payment {
  id                  String    @id @default(uuid())
  userId              String
  type                String    @default("one_time") // one_time, subscription, category_purchase, domain_purchase, academy_purchase
  status              String    @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  
  // Amount details
  amount              Decimal
  currency            String    @default("NGN")
  amountInKobo         Int?      // For NGN payments
  amountInCents        Int?      // For USD payments
  
  // Paystack
  paystackReference   String?
  paystackRef         String?   // Alias for paystackReference
  paystackId          String?
  channel             String?
  paystackChannel     String?
  authorizationCode   String?
  paystackFees        Decimal?
  
  // Gateway response
  gatewayResponse     Json?
  
  // References for new purchase types
  categoryPurchaseId  String?
  domainPurchaseId    String?
  academyPurchaseId   String?
  
  // Metadata
  metadata            Json?
  
  // Timestamps
  initiatedAt         DateTime  @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  refundedAt          DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paystackRef])
  @@index([status])
  @@index([type])
  @@map("payments")
}

// ============================================
// 13. SUBSCRIPTIONS - Membership subscriptions (Legacy)
// ============================================

model Subscription {
  id                       String    @id @default(uuid())
  userId                   String
  planId                   String?
  planName                 String    @default("FREE") // FREE, PRO, TEAM (legacy)
  status                   String    @default("active") // active, cancelled, expired, trialing
  startDate                DateTime  @default(now())
  endDate                  DateTime?
  recurringPrice           Decimal?
  isPro                    Boolean   @default(false)
  autoRenew                Boolean   @default(true)
  paystackSubscriptionCode String?
  stripeSubscriptionId     String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("subscriptions")
}

// ============================================
// 14b. PRICING PLAN PURCHASE SCOPE
// ============================================
enum PurchaseScope {
  ACADEMY     // Full platform access
  DOMAIN      // All categories within specific domain(s)
  CATEGORY    // All courses within specific category(ies)
}

model Plan {
  id                 String   @id @default(uuid())
  name               String
  description        String?  @db.Text
  planType           String   @default("subscription") // subscription, one_time
  billingCycle       String   @default("monthly") // monthly, yearly, lifetime
  
  // Purchase Scope - NEW FIELD
  purchaseScope      PurchaseScope @default(CATEGORY)
  
  // For Domain Scope - which domains this plan covers
  allowedDomainIds   String[] @default([])
  
  // For Category Scope - which categories this plan covers
  allowedCategoryIds String[] @default([])
  
  // Legacy fields
  price              Decimal  @default(0) // Legacy single price
  currency           String   @default("USD") // Legacy single currency
  pricing            Json? // Multi-currency: { "NGN": { "amount": 50000, "paystackPlanId": "xxx" }, "USD": { "amount": 100, "stripePriceId": "xxx" } }
  stripePriceId      String?  @unique // Legacy
  paystackPlanId     String?  @unique // Legacy
  features           Json?    @default("[]")
  isActive           Boolean  @default(true)
  isFeatured         Boolean  @default(false)
  discountPercentage Int?     @default(0) // For limited-time offers
  promoCode          String?
  maxCourses         Int?     @default(-1) // -1 for unlimited
  maxCertificates    Int?     @default(-1)
  trialDays          Int?     @default(0)
  sortOrder          Int      @default(0)
  
  // Visual customization
  icon               String?
  bannerUrl          String?
  themeColor         String?
  
  // Status
  status             String   @default("PUBLISHED") // DRAFT, PUBLISHED, ARCHIVED
  visibility         String   @default("PUBLIC") // PUBLIC, PRIVATE
  isPopular          Boolean  @default(false)
  isRecommended      Boolean  @default(false)
  
  // SEO
  seoTitle           String?
  seoDescription     String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  subscriptions      Subscription[]
  categoryPurchases  CategoryPurchase[]
  domainPurchases    DomainPurchase[]
  academyPurchases   AcademyPurchase[]
  discountCampaigns  DiscountCampaign[]

  @@map("plans")
}

// ============================================
// 14c. CATEGORY PURCHASE - One-time purchase for category access
// ============================================
model CategoryPurchase {
  id              String    @id @default(uuid())
  userId          String
  planId          String?   // Optional - which plan was used
  categoryId      String
  categoryName    String    // Denormalized for quick access
  domainId        String?   // Domain this category belongs to
  domainName      String?   // Denormalized
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt       DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef     String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id])
  
  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("category_purchases")
}

// ============================================
// 14d. DOMAIN PURCHASE - One-time purchase for domain access (all categories)
// ============================================
model DomainPurchase {
  id              String    @id @default(uuid())
  userId          String
  planId          String?   // Optional - which plan was used
  domainId        String
  domainName      String    // Denormalized for quick access
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt      DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef    String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan  Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  domain Domain  @relation(fields: [domainId], references: [id])
  
  @@unique([userId, domainId])
  @@index([userId])
  @@index([domainId])
  @@index([status])
  @@map("domain_purchases")
}

// ============================================
// 14e. ACADEMY PURCHASE - One-time purchase for entire platform access
// ============================================
model AcademyPurchase {
  id              String    @id @default(uuid())
  userId          String
  planId          String?   // Optional - which plan was used
  
  // Payment details
  amountPaid      Decimal   @default(0)
  currency        String    @default("USD")
  paymentId       String?   // Reference to Payment model
  
  // Status
  status          String    @default("active") // active, refunded, cancelled
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime? // Null for lifetime
  refundedAt      DateTime?
  refundReason    String?
  
  // Coupons & Discounts
  couponId        String?
  couponCode      String?
  discountAmount  Decimal   @default(0)
  
  // Invoice
  invoiceId       String?
  
  // Paystack reference
  paystackRef    String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  
  @@unique([userId])
  @@index([userId])
  @@index([status])
  @@map("academy_purchases")
}
// ============================================
model Invoice {
  id              String    @id @default(uuid())
  invoiceNumber   String    @unique // INV-2024-00001
  
  userId          String
  userEmail       String
  
  // Line items
  items           Json      // [{ description, quantity, unitPrice, total, planId, scope }]
  
  // Totals
  subtotal        Decimal   @default(0)
  discountAmount  Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  currency        String    @default("USD")
  
  // Status
  status          String    @default("draft") // draft, issued, paid, cancelled, refunded
  dueDate         DateTime?
  paidAt          DateTime?
  
  // Payment
  paymentId       String?
  
  // References
  couponId        String?
  couponCode      String?
  
  // Address
  billingAddress  Json?
  
  // Notes
  notes           String?
  terms           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
  @@map("invoices")
}

// ============================================
// 14h. COUPON - Discount codes
// ============================================
model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  
  // Discount type
  discountType    String    // percentage, fixed_amount
  discountValue   Decimal   // Percentage (0-100) or fixed amount
  
  // Currency for fixed discounts
  currency        String    @default("USD")
  
  // Limits
  maxUses         Int?      // Null = unlimited
  currentUses     Int       @default(0)
  maxUsesPerUser  Int       @default(1)
  
  // Validity
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  
  // Scope - which plans/products this applies to
  applicableScope String    @default("all") // all, academy, domain, category, specific_plan
  applicablePlanIds String[] @default([]) // If specific_plan
  applicableDomainIds String[] @default([])
  applicableCategoryIds String[] @default([])
  
  // Status
  isActive        Boolean   @default(true)
  isPublic        Boolean   @default(true) // Public vs admin-only
  
  // Requirements
  minPurchaseAmount Decimal?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  discountCampaigns DiscountCampaign[]
  
  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

// ============================================
// 14i. DISCOUNT CAMPAIGN - Time-limited offers
// ============================================
model DiscountCampaign {
  id              String    @id @default(uuid())
  name            String
  description     String?
  
  // Discount
  discountType    String    // percentage, fixed_amount
  discountValue   Decimal
  currency        String    @default("USD")
  
  // Target
  targetType      String    // all, specific_plan, domain, category
  planId          String?
  domainId        String?
  categoryId      String?
  
  // Validity
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  
  // Coupon association (optional - some campaigns need code)
  couponId        String?
  couponCode      String?
  requiresCoupon  Boolean   @default(false)
  
  // Display
  displayBanner   Boolean   @default(true)
  bannerText      String?
  bannerColor     String?
  
  // Limits
  maxRedemptions Int?      // Null = unlimited
  currentRedemptions Int   @default(0)
  
  // Status
  isActive        Boolean   @default(true)
  
  // Priority (for stacking with other discounts)
  priority        Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan Plan       @relation(fields: [planId], references: [id], onDelete: SetNull)
  coupon Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)
  
  @@index([isActive])
  @@index([startsAt, endsAt])
  @@map("discount_campaigns")
}

// ============================================
// 14j. ACCESS LICENSE - Granular access control
// ============================================
model AccessLicense {
  id              String    @id @default(uuid())
  userId          String
  licenseType     String    // academy, domain, category, course
  targetId        String    // domainId, categoryId, or courseId depending on type
  
  // Status
  status          String    @default("active") // active, expired, revoked
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?
  
  // Source
  sourceType      String    // purchase, admin_grant, trial, subscription
  purchaseId      String?   // Reference to CategoryPurchase, DomainPurchase, or AcademyPurchase
  grantedByAdminId String?  // If admin granted access
  
  // Auto-enrollment tracking
  coursesEnrolled Int       @default(0)
  lastEnrolledAt  DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, licenseType, targetId])
  @@index([userId])
  @@index([licenseType, targetId])
  @@index([status])
  @@map("access_licenses")
}

// ============================================

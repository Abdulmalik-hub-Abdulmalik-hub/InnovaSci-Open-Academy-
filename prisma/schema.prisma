model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info") // info, success, warning, error
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ============================================
// 19. AUDIT LOGS - Activity tracking
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String // SELECT, INSERT, UPDATE, DELETE, EXPORT, etc.
  module       String // STORAGE, DB_EXPLORER, USERS, etc.
  targetTable  String? // Table being accessed
  targetId     String? // Specific row ID
  query        String?  @db.Text // Query executed
  affectedRows Int? // Number of rows affected
  previousData Json? // For UPDATE/DELETE - stores original data
  newData      Json? // For INSERT/UPDATE - stores new data
  details      Json?
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Indexes for fast querying
  @@index([createdAt])
  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([targetTable])
  @@map("audit_logs")
}


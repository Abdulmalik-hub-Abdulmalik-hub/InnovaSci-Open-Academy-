// =============================================================================
// INNOVASCI OPEN ACADEMY - MASTER COURSE CREATION SYSTEM (MCCS)
// =============================================================================
// This schema implements the MCCS Hierarchy:
// Academy → Category → DifficultyLevel → Course → Module → Lesson → 
// PracticalExercise → MiniProject → DifficultyLevelCapstone → 
// ProfessionalCapstone → Certificate
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. ACADEMY - Top-level organizational unit
// =============================================================================

model Academy {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  categories Category[]

  @@map("academies")
}

// =============================================================================
// 2. CATEGORIES - Domain/Topic grouping within Academy
// =============================================================================

model Category {
  id           String   @id @default(uuid())
  academyId    String?
  name         String
  slug         String   @unique
  description  String?  @db.Text
  icon         String?  // Icon name or emoji
  color        String?  // Hex color code
  orderIndex   Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  academy              Academy?               @relation(fields: [academyId], references: [id], onDelete: SetNull)
  difficultyLevels     DifficultyLevel[]
  courses              Course[]
  professionalCapstones ProfessionalCapstone[]

  @@index([academyId])
  @@index([isActive])
  @@map("categories")
}

// =============================================================================
// 3. DIFFICULTY LEVELS - Skill progression tiers within Category
// =============================================================================

model DifficultyLevel {
  id          String   @id @default(uuid())
  categoryId  String
  name        String   // Beginner, Intermediate, Advanced, Expert
  slug        String   @unique
  description String?  @db.Text
  orderIndex  Int      @default(0)
  color       String?  // Hex color for UI distinction
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  category               Category?                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  courses                Course[]
  difficultyLevelCapstones DifficultyLevelCapstone[]

  @@unique([categoryId, orderIndex])
  @@index([categoryId])
  @@index([isActive])
  @@map("difficulty_levels")
}

// =============================================================================
// 4. INSTRUCTORS - Content creators/teachers
// =============================================================================

model Instructor {
  id           String   @id @default(uuid())
  userId       String?  @unique
  name         String
  slug         String   @unique
  email        String   @unique
  bio          String?  @db.Text
  avatarUrl    String?
  expertise    String[] // Areas of expertise
  socialLinks  Json?    // {linkedin, twitter, github, website}
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user       User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  courses    CourseInstructor[]
  certificates Certificate[] // For instructor-generated certificates

  @@index([userId])
  @@index([isActive])
  @@map("instructors")
}

// =============================================================================
// 5. COURSES - Primary learning unit
// =============================================================================

model Course {
  id                  String   @id @default(uuid())
  title               String
  slug                String   @unique
  categoryId          String?
  difficultyLevelId   String?
  instructorId        String?
  
  // Basic Info
  shortDescription    String?  @db.Text
  fullDescription     String?  @db.Text
  
  // Branding & Media
  thumbnailUrl        String?
  promoVideoUrl       String?
  introVideoUrl       String?  // Mandatory intro video
  trailerVideoUrl     String?
  
  // Learning Info
  language            String   @default("English")
  durationHours       Int?
  difficultyLevel     String?  // Legacy field
  targetAudience      String?
  
  // Pricing
  price               Decimal  @default(0) @db.Decimal(10, 2)
  isFree              Boolean  @default(true)
  pricing             Json?    // Multi-currency: { "NGN": { "amount": 50000 }, "USD": { "amount": 100 } }
  
  // Status & Visibility
  status              CourseStatus @default(DRAFT) // DRAFT, PUBLISHED, ARCHIVED, UNDER_REVIEW
  isActive            Boolean  @default(true)
  publishedAt         DateTime?
  
  // SEO
  metaTitle           String?
  metaDescription     String?
  keywords            String[]
  
  // Certificate
  certificateTemplateId String?
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  category            Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  difficultyLevel     DifficultyLevel?       @relation(fields: [difficultyLevelId], references: [id], onDelete: SetNull)
  
  // Content
  modules             Module[]
  miniProjects        MiniProject[]
  
  // Relations
  instructors         CourseInstructor[]
  enrollments         Enrollment[]
  certificates        Certificate[]
  wishlists           Wishlist[]
  learningProgress    LearningProgress[]
  
  // Learning Outcomes
  learningOutcomes    CourseLearningOutcome[]
  objectives          CourseObjective[]
  
  // Resources
  resources           CourseResource[]
  software            CourseSoftware[]
  datasets            CourseDataset[]
  
  // Prerequisites
  prerequisites       Prerequisite[]         @relation("PrerequisiteCourse")
  dependentCourses    Prerequisite[]         @relation("DependentCourse")
  
  // Capstone Links
  difficultyLevelCapstones DifficultyLevelCapstoneCourse[]
  
  // Issued Certificates
  issuedCertificates  IssuedCertificate[]
  
  // Learning Paths
  learningPaths       LearningPathCourse[]
  
  // Certificate Template
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id], onDelete: SetNull)
  
  // SEO
  seoSettings         CourseSeoSettings?

  @@index([categoryId])
  @@index([difficultyLevelId])
  @@index([status])
  @@index([isActive])
  @@index([slug])
  @@map("courses")
}

enum CourseStatus {
  DRAFT
  UNDER_REVIEW
  PUBLISHED
  ARCHIVED
}

// =============================================================================
// 6. COURSE INSTRUCTOR (Junction Table)
// =============================================================================

model CourseInstructor {
  id           String   @id @default(uuid())
  courseId     String
  instructorId String
  role         InstructorRole @default(PRIMARY) // PRIMARY, CO_INSTRUCTOR, GUEST
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([courseId, instructorId])
  @@index([courseId])
  @@index([instructorId])
  @@map("course_instructors")
}

enum InstructorRole {
  PRIMARY
  CO_INSTRUCTOR
  GUEST
}

// =============================================================================
// 7. COURSE SEO SETTINGS
// =============================================================================

model CourseSeoSettings {
  id                  String  @id @default(uuid())
  courseId            String  @unique
  metaTitle           String?
  metaDescription     String?
  keywords            String[]
  canonicalUrl        String?
  ogImageUrl          String?
  noIndex             Boolean @default(false)
  noFollow            Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_seo_settings")
}

// =============================================================================
// 8. MODULES - Course sections
// =============================================================================

model Module {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  description  String?  @db.Text
  orderIndex   Int      @default(0)
  isPreview    Boolean  @default(false) // Preview module without enrollment
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  course              Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons             Lesson[]
  practicalExercises  PracticalExercise[]

  @@unique([courseId, orderIndex])
  @@index([courseId])
  @@map("modules")
}

// =============================================================================
// 9. LESSONS - Individual learning items within Module
// =============================================================================

model Lesson {
  id           String     @id @default(uuid())
  courseId     String
  moduleId     String?
  title        String
  description  String?    @db.Text
  orderIndex   Int        @default(0)
  lessonType   LessonType @default(VIDEO) // VIDEO, TEXT, QUIZ, EXERCISE, LIVE
  
  // Video Content
  videoUrl     String?
  videoDuration Int?      // Duration in seconds
  videoProvider String?   // youtube, vimeo, local
  
  // Preview & Access
  isPreview     Boolean   @default(false)
  isFree        Boolean   @default(false)
  isActive      Boolean   @default(true)
  
  // Content
  content       String?   @db.Text // Rich text/HTML content
  contentUrl    String?   // Link to external content
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  course          Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module          Module?               @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  materials       Material[]
  videos          Video[]
  progress        LearningProgress[]
  lectureProgress UserLectureProgress[]
  practicalExercises PracticalExercise[]

  @@unique([courseId, orderIndex])
  @@index([courseId])
  @@index([moduleId])
  @@index([lessonType])
  @@index([isActive])
  @@map("lessons")
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  EXERCISE
  LIVE
  RESOURCE
}

// =============================================================================
// 10. PRACTICAL EXERCISES - Hands-on exercises per lesson
// =============================================================================

model PracticalExercise {
  id           String   @id @default(uuid())
  lessonId     String
  moduleId     String?
  courseId     String
  
  // Basic Info
  title        String
  description  String?  @db.Text
  orderIndex   Int      @default(0)
  
  // Exercise Content
  instructions String   @db.Text // Step-by-step instructions
  hints        Json?    // Array of hints with levels: [{level: 1, text: "..."}]
  
  // Files & Resources
  starterFilesUrl String? // URL to downloadable starter files
  solutionFilesUrl String? // URL to solution files
  solutionVideoUrl String? // URL to solution walkthrough
  
  // Rubrics
  rubrics       Json?    // Evaluation rubrics: [{criterion: "...", points: 10, description: "..."}]
  passingScore  Int      @default(70)
  
  // Environment
  environmentType String? // browser, local, docker, jupyter
  setupInstructions String? @db.Text
  
  // Metadata
  estimatedTime Int?     // Estimated completion time in minutes
  difficulty     String?  // easy, medium, hard
  tags           String[]
  
  // Status
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  lesson        Lesson?              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  module        Module?               @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  course        Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions   ExerciseSubmission[]

  @@index([lessonId])
  @@index([courseId])
  @@index([isPublished])
  @@map("practical_exercises")
}

// =============================================================================
// 10A. EXERCISE SUBMISSIONS - Student submissions for exercises
// =============================================================================

model ExerciseSubmission {
  id               String           @id @default(uuid())
  exerciseId       String
  userId           String
  
  // Submission Content
  submissionUrl     String?          // GitHub repo or file URL
  submissionNotes   String?          @db.Text
  submittedFiles    Json?            // List of submitted file names/paths
  
  // Grading
  score            Int?
  feedback         String?           @db.Text
  gradedAt         DateTime?
  gradedBy         String?
  
  // Status
  status            SubmissionStatus @default(SUBMITTED) // SUBMITTED, GRADED, REVISION_REQUESTED
  
  // Timestamps
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  exercise         PracticalExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
  @@index([status])
  @@map("exercise_submissions")
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  REVISION_REQUESTED
  ACCEPTED
}

// =============================================================================
// 11. MINI PROJECTS - Course-level practical projects
// =============================================================================

model MiniProject {
  id           String   @id @default(uuid())
  courseId     String
  
  // Basic Info
  title        String
  description  String?  @db.Text
  orderIndex   Int      @default(0)
  
  // Scenario
  scenario     String?  @db.Text // Real-world scenario context
  objectives   String[] // Learning objectives for this project
  
  // Workflow
  deliverables String[] // Required deliverables
  workflowSteps Json?    // Step-by-step workflow: [{step: 1, title: "...", description: "..."}]
  
  // Resources
  starterFilesUrl String?
  referenceFilesUrl String?
  
  // Evaluation
  rubrics       Json?    // [{criterion: "...", points: 20, description: "..."}]
  passingScore  Int      @default(70)
  evaluationCriteria String? @db.Text
  
  // Environment
  environmentSetup String? @db.Text
  technicalRequirements Json? // {tools: [...], packages: [...], environment: "..."}
  
  // Metadata
  estimatedHours Int?
  difficulty     String?
  tags           String[]
  
  // Status
  isPublished   Boolean  @default(false)
  deadline       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  course        Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions   ProjectSubmission[]

  @@index([courseId])
  @@index([isPublished])
  @@map("mini_projects")
}

// =============================================================================
// 11A. PROJECT SUBMISSIONS - Student submissions for mini projects
// =============================================================================

model ProjectSubmission {
  id               String             @id @default(uuid())
  projectId        String
  userId           String
  
  // Submission Content
  projectTitle     String?
  submissionUrl    String?           // GitHub repo URL
  liveDemoUrl       String?
  documentationUrl String?
  submissionNotes   String?           @db.Text
  screenshots       Json?              // Array of screenshot URLs
  
  // Team (if applicable)
  teamMembers       Json?              // [{name: "...", email: "..."}]
  isTeamSubmission  Boolean @default(false)
  
  // Grading
  score            Int?
  percentageScore  Decimal? @db.Decimal(5, 2)
  feedback         String?  @db.Text
  gradedAt         DateTime?
  gradedBy         String?
  
  // Status
  status           ProjectStatus @default(SUBMITTED) // SUBMITTED, UNDER_REVIEW, REVISION_REQUESTED, GRADED, ACCEPTED
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  project          MiniProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("project_submissions")
}

enum ProjectStatus {
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  GRADED
  ACCEPTED
}

// =============================================================================
// 12. DIFFICULTY LEVEL CAPSTONES - Capstones combining courses of same difficulty
// =============================================================================

model DifficultyLevelCapstone {
  id              String   @id @default(uuid())
  difficultyLevelId String
  
  // Basic Info
  title           String
  slug            String   @unique
  description     String?  @db.Text
  orderIndex      Int      @default(0)
  
  // Requirements
  requiredCourses Int      @default(1) // Minimum courses required to attempt
  requiredCourseIds String[] // Specific course IDs that must be completed
  
  // Project
  projectTitle    String?
  projectDescription String? @db.Text
  projectRequirements String? @db.Text
  
  // Resources
  starterFilesUrl String?
  referenceMaterialsUrl String?
  
  // Evaluation
  rubrics         Json?    // [{criterion: "...", points: 20, description: "..."}]
  passingScore    Int      @default(70)
  
  // Certificate
  certificateTemplateId String?
  
  // Status
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  difficultyLevel DifficultyLevel?        @relation(fields: [difficultyLevelId], references: [id], onDelete: Cascade)
  courses         DifficultyLevelCapstoneCourse[]
  submissions     CapstoneSubmission[]

  @@index([difficultyLevelId])
  @@index([isActive])
  @@map("difficulty_level_captstones")
}

model DifficultyLevelCapstoneCourse {
  id           String   @id @default(uuid())
  capstoneId   String
  courseId     String
  isRequired   Boolean  @default(true)
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())

  capstone     DifficultyLevelCapstone @relation(fields: [capstoneId], references: [id], onDelete: Cascade)
  course       Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([capstoneId, courseId])
  @@index([capstoneId])
  @@index([courseId])
  @@map("difficulty_level_capstone_courses")
}

// =============================================================================
// 13. PROFESSIONAL CAPSTONES - Capstones combining all courses in a category
// =============================================================================

model ProfessionalCapstone {
  id           String   @id @default(uuid())
  categoryId   String
  
  // Basic Info
  title        String
  slug         String   @unique
  description  String?  @db.Text
  orderIndex   Int      @default(0)
  
  // Requirements
  requiredDifficultyLevels Int @default(1) // Number of difficulty levels to complete
  requiredCourses          Int @default(1) // Total courses required
  
  // Project
  projectTitle           String?
  projectDescription     String? @db.Text
  projectRequirements     String? @db.Text
  projectDeliverables     String[]
  
  // Resources
  starterFilesUrl         String?
  referenceMaterialsUrl   String?
  additionalResourcesUrl  String?
  
  // Evaluation
  rubrics         Json?    // [{criterion: "...", points: 20, description: "..."}]
  passingScore    Int      @default(70)
  
  // Certificate
  certificateTemplateId   String?
  
  // Status
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  category       Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  difficultyLevelCaptones DifficultyLevelCapstone[]
  submissions    ProfessionalCapstoneSubmission[]

  @@index([categoryId])
  @@index([isActive])
  @@map("professional_captstones")
}

// =============================================================================
// 13A. PROFESSIONAL CAPSTONE SUBMISSIONS
// =============================================================================

model ProfessionalCapstoneSubmission {
  id               String             @id @default(uuid())
  capstoneId       String
  userId           String
  
  // Submission Content
  projectTitle     String?
  submissionUrl    String?           // GitHub repo URL
  liveDemoUrl      String?
  documentationUrl String?
  presentationUrl  String?           // Demo video/presentation URL
  submissionNotes  String?           @db.Text
  
  // Team
  teamName         String?
  teamMembers      Json?             // [{name: "...", email: "...", role: "..."}]
  isTeamSubmission Boolean @default(false)
  
  // Grading
  score            Int?
  percentageScore  Decimal? @db.Decimal(5, 2)
  feedback         String?  @db.Text
  gradedAt         DateTime?
  gradedBy         String?
  
  // Status
  status           ProfessionalCapstoneStatus @default(SUBMITTED)
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  capstone         ProfessionalCapstone @relation(fields: [capstoneId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([capstoneId])
  @@index([userId])
  @@index([status])
  @@map("professional_capstone_submissions")
}

enum ProfessionalCapstoneStatus {
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  GRADED
  ACCEPTED
  CERTIFIED
}

// =============================================================================
// 14. CAPSTONE SUBMISSIONS - For DifficultyLevelCapstones
// =============================================================================

model CapstoneSubmission {
  id               String           @id @default(uuid())
  capstoneId       String
  userId           String
  
  // Submission Content
  projectTitle     String?
  submissionUrl    String?
  liveDemoUrl      String?
  documentationUrl String?
  submissionNotes  String?          @db.Text
  
  // Team
  isTeamSubmission Boolean @default(false)
  teamName         String?
  teamMembers      Json?
  
  // Grading
  score            Int?
  percentageScore  Decimal? @db.Decimal(5, 2)
  feedback         String?  @db.Text
  gradedAt         DateTime?
  gradedBy         String?
  
  // Status
  status           CapstoneStatus @default(SUBMITTED)
  
  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  capstone         DifficultyLevelCapstone @relation(fields: [capstoneId], references: [id], onDelete: Cascade)
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([capstoneId])
  @@index([userId])
  @@index([status])
  @@map("capstone_submissions")
}

enum CapstoneStatus {
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  GRADED
  ACCEPTED
  CERTIFIED
}

// =============================================================================
// 15. COURSE LEARNING OUTCOMES
// =============================================================================

model CourseLearningOutcome {
  id          String   @id @default(uuid())
  courseId    String
  outcome     String   @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, orderIndex])
  @@index([courseId])
  @@map("course_learning_outcomes")
}

// =============================================================================
// 16. COURSE OBJECTIVES
// =============================================================================

model CourseObjective {
  id          String   @id @default(uuid())
  courseId    String
  objective   String   @db.Text
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, orderIndex])
  @@index([courseId])
  @@map("course_objectives")
}

// =============================================================================
// 17. COURSE RESOURCES (Links, downloads, etc.)
// =============================================================================

model CourseResource {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  type        ResourceType
  url         String
  description String?
  isDownloadable Boolean @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_resources")
}

enum ResourceType {
  LINK
  DOWNLOAD
  DOCUMENT
  EXTERNAL_COURSE
  TOOL
}

// =============================================================================
// 18. COURSE SOFTWARE (Required tools, IDEs, etc.)
// =============================================================================

model CourseSoftware {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  version     String?
  websiteUrl  String?
  installInstructions String? @db.Text
  isRequired  Boolean  @default(true)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_software")
}

// =============================================================================
// 19. COURSE DATASETS
// =============================================================================

model CourseDataset {
  id          String   @id @default(uuid())
  courseId    String
  name        String
  description String?
  sourceUrl   String?
  downloadUrl String?
  fileSize    String?
  format      String?  // csv, json, xlsx, etc.
  license     String?
  isRequired  Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_datasets")
}

// =============================================================================
// 20. PREREQUISITES (Course dependencies)
// =============================================================================

model Prerequisite {
  id              String   @id @default(uuid())
  courseId        String   // Course that has the prerequisite
  prerequisiteCourseId String // Required course
  isRequired      Boolean  @default(true)
  minimumGrade    Int?     // Minimum completion percentage required
  description     String?
  createdAt       DateTime @default(now())

  // Self-relations for course prerequisites
  course           Course @relation("PrerequisiteCourse", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisiteCourse Course @relation("DependentCourse", fields: [prerequisiteCourseId], references: [id], onDelete: Cascade)

  @@unique([courseId, prerequisiteCourseId])
  @@index([courseId])
  @@index([prerequisiteCourseId])
  @@map("prerequisites")
}

// =============================================================================
// 21. CAREER OUTCOMES
// =============================================================================

model CareerOutcome {
  id          String   @id @default(uuid())
  courseId    String
  title       String   // e.g., "Data Scientist", "ML Engineer"
  description String?  @db.Text
  probability String?  // high, medium, low
  salaryRange String?  // e.g., "$80,000 - $120,000"
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("career_outcomes")
}

// =============================================================================
// 22. CERTIFICATES - Certificate templates
// =============================================================================

model Certificate {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?  @db.Text
  
  // Template
  templateUrl  String?  // URL to template file
  templateData Json?    // {background, logo, signature, etc.}
  
  // Validity
  validityPeriod Int?   // In days, null = never expires
  isRenewable   Boolean @default(false)
  
  // Requirements
  minimumCompletion Float @default(100) // Percentage required
  requireProject    Boolean @default(false)
  
  // Branding
  primaryColor    String?
  secondaryColor  String?
  
  // Status
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  instructor    Instructor?          @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  instructorId  String?
  courses       Course[]
  issuedCertificates IssuedCertificate[]

  @@index([isActive])
  @@map("certificates")
}

// =============================================================================
// 23. ISSUED CERTIFICATES - Certificates earned by students
// =============================================================================

model IssuedCertificate {
  id           String   @id @default(uuid())
  certificateId String
  userId       String
  courseId     String?
  
  // Certificate Details
  certificateNumber String   @unique
  title         String
  recipientName String
  
  // Verification
  verificationUrl String?   // Public URL to verify certificate
  verificationCode String  @unique
  
  // Dates
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  
  // Grade/Score
  finalScore    Float?
  completionPercentage Float?
  
  // Metadata
  metadata      Json?     // Additional data
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([certificateId])
  @@index([userId])
  @@index([courseId])
  @@index([verificationCode])
  @@map("issued_certificates")
}

// =============================================================================
// 24. CERTIFICATE TEMPLATES - Visual templates for certificates
// =============================================================================

model CertificateTemplate {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  
  // Template Design
  templateUrl  String?  // URL to template file
  templateData Json?    // Design specifications
  
  // Layout
  layout       Json?    // {width, height, orientation, margins}
  elements     Json?    // [{type: "text", x: 100, y: 200, ...}]
  
  // Branding
  logoUrl      String?
  signatureUrl String?
  watermarkUrl String?
  
  // Colors
  primaryColor   String?
  secondaryColor String?
  textColor      String?
  
  // Status
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  courses      Course[]

  @@index([isActive])
  @@index([isDefault])
  @@map("certificate_templates")
}


# ============================================
# INNOVASCI OPEN ACADEMY - ENVIRONMENT VARIABLES
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/innovasci_db"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Resend (Email)
RESEND_API_KEY="re_your-api-key"

# Cloudflare R2
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="innovasci-assets"

# ============================================
# Paystack Payment Gateway
# ============================================
# Get your keys from: https://paystack.com/dashboard/settings/api
#
# Test mode keys (for development):
# - Use 'sk_test_' and 'pk_test_' prefixes
# Production mode keys (for live):
# - Use 'sk_live_' and 'pk_live_' prefixes

# Paystack Secret Key (Server-side only - NEVER expose to frontend)
PAYSTACK_SECRET_KEY="sk_test_your_secret_key"

# Paystack Public Key (Safe to expose to frontend)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_your_public_key"

# Paystack Webhook Secret (For verifying webhook signatures)
# Get this from Paystack Dashboard > Settings > Webhooks
PAYSTACK_WEBHOOK_SECRET="your_webhook_secret"

# ============================================
# Application Settings
# ============================================

# Application URL (for payment callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
